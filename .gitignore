# macOS
.DS_Store

# Environment
.env
.env.local

# Legacy indicator versions (pre-git historical record, frozen)
08_TradingView_Indicators/Legacy Versions/

# Claude Code session data
.claude/*.jsonl

# Python bytecode
**/__pycache__/
**/*.pyc
**/*.pyo

# Claude Code runtime state (session-specific, not version-controlled)
.claude/memory/
.claude/primer.md
.claude/learning/
.claude/incidents/
.claude/adaptations/
.claude/context/
.claude/handoff/
.claude/review/
.claude/rollout/
.claude/reports/
.claude/evals/

# Project-OS overlay (auto-generated, lives in ~/.project-os)
.project-os/
.claude/.local-overrides.md

# Candle store data (fetched at runtime, not versioned)
execution/market_data/data/

# Session context (runtime state, not versioned)
context/session.md
context/regime_signal.json

# Agentic QS pipeline runs (generated artifacts, not versioned)
execution/agents/output/

# Results — data cache (large CSVs, regenerated at runtime)
results/data_cache/

# Results — TradingAgents full state dumps (200KB+, not useful to version)
results/**/full_states_log*.json

# Runtime lock files
.claude/scheduled_tasks.lock

# Third-party tooling dirs (not part of this project)
.agents/
.antigravitycli/
.kiro/
skills-lock.json
