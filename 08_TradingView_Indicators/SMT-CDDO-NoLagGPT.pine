float r1PH_40 = need1R3 and useCloseBreak and ref1H > ta.highest(ref1H[1], 40) ? ref1H : na, float r1PL_40 = need1R3 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 40)  ? ref1L : na
float r1PH_45 = need1R3 and useCloseBreak and ref1H > ta.highest(ref1H[1], 45) ? ref1H : na, float r1PL_45 = need1R3 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 45)  ? ref1L : na
