float r3PH_50 = need3R3 and useCloseBreak and ref3H > ta.highest(ref3H[1], 50) ? ref3H : na, float r3PL_50 = need3R3 and useCloseBreak and ref3L < ta.lowest(ref3L[1], 50)  ? ref3L : na
