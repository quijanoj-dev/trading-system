float r1PH_60 = need1R3 and useCloseBreak and ref1H > ta.highest(ref1H[1], 60) ? ref1H : na, float r1PL_60 = need1R3 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 60)  ? ref1L : na

// Ref2 swings
bool need2R1 = needR1 and sym2On, bool need2R2 = needR2 and sym2On, bool need2R3 = needR3 and sym2On
float r2PH_2  = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 2)  ? ref2H : na, float r2PL_2  = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 2)   ? ref2L : na
float r2PH_3  = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 3)  ? ref2H : na, float r2PL_3  = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 3)   ? ref2L : na
float r2PH_5  = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 5)  ? ref2H : na, float r2PL_5  = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 5)   ? ref2L : na
float r2PH_6  = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 6)  ? ref2H : na, float r2PL_6  = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 6)   ? ref2L : na
float r2PH_8  = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 8)  ? ref2H : na, float r2PL_8  = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 8)   ? ref2L : na
float r2PH_10 = need2R1 and useCloseBreak and ref2H > ta.highest(ref2H[1], 10) ? ref2H : na, float r2PL_10 = need2R1 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 10)  ? ref2L : na
float r2PH_12 = need2R2 and useCloseBreak and ref2H > ta.highest(ref2H[1], 12) ? ref2H : na, float r2PL_12 = need2R2 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 12)  ? ref2L : na
float r2PH_14 = need2R2 and useCloseBreak and ref2H > ta.highest(ref2H[1], 14) ? ref2H : na, float r2PL_14 = need2R2 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 14)  ? ref2L : na
float r2PH_17 = need2R2 and useCloseBreak and ref2H > ta.highest(ref2H[1], 17) ? ref2H : na, float r2PL_17 = need2R2 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 17)  ? ref2L : na
float r2PH_20 = need2R2 and useCloseBreak and ref2H > ta.highest(ref2H[1], 20) ? ref2H : na, float r2PL_20 = need2R2 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 20)  ? ref2L : na
