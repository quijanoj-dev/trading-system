float r1PH_14 = need1R2 and useCloseBreak and ref1H > ta.highest(ref1H[1], 14) ? ref1H : na, float r1PL_14 = need1R2 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 14)  ? ref1L : na
float r1PH_17 = need1R2 and useCloseBreak and ref1H > ta.highest(ref1H[1], 17) ? ref1H : na, float r1PL_17 = need1R2 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 17)  ? ref1L : na
