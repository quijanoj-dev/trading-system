// ████████████████████████████████████████████████████████████████████████
// UDT: Unified SMT + CDDO bubble
// ████████████████████████████████████████████████████████████████████████
type SMTSignal
    int    barIdx
    float  pivotPrice
    bool   isBear
    string symName
    int    pivotLen
    label  lbl
    line   ln
    bool   invalidated
    bool   hasSMT
    bool   hasCDDO
    string smtText
    string cddoText
    float  smtPivotPrice
    float  cddoPivotPrice
    bool   smtInvalidated
    bool   cddoInvalidated
    bool   removed

var array<SMTSignal> signals = array.new<SMTSignal>()

// ████████████████████████████████████████████████████████████████████████
// STATE MAPS — persist last/prev pivots per (symbol, length) combo
// ████████████████████████████████████████████████████████████████████████
var map<string, float> lastPH  = map.new<string, float>()
var map<string, float> prevPH  = map.new<string, float>()
var map<string, int>   lastPHi = map.new<string, int>()
var map<string, int>   prevPHi = map.new<string, int>()
var map<string, float> lastPL  = map.new<string, float>()
var map<string, float> prevPL  = map.new<string, float>()
var map<string, int>   lastPLi = map.new<string, int>()
var map<string, int>   prevPLi = map.new<string, int>()
var map<string, float> rLastPH  = map.new<string, float>()
var map<string, float> rPrevPH  = map.new<string, float>()
var map<string, int>   rLastPHi = map.new<string, int>()
var map<string, int>   rPrevPHi = map.new<string, int>()
var map<string, float> rLastPL  = map.new<string, float>()
var map<string, float> rPrevPL  = map.new<string, float>()
var map<string, int>   rLastPLi = map.new<string, int>()
var map<string, int>   rPrevPLi = map.new<string, int>()

// Dedup + merged bubble state
var map<string, int>    dedupCount   = map.new<string, int>()
var map<string, string> dedupSyms    = map.new<string, string>()
var map<string, int>    dedupSeenBar = map.new<string, int>()
var map<string, int>    signalIdxKey = map.new<string, int>()
var array<int>          signalOrder  = array.new_int()
var array<int>          activeSignals = array.new_int()
var array<int>          smtHistory   = array.new_int()

// Swing dedup — only push last→prev when opposite-direction breakout fired in between
var map<string, bool> hadLowSinceHigh    = map.new<string, bool>()
var map<string, bool> hadHighSinceLow    = map.new<string, bool>()
var map<string, bool> rHadLowSinceHigh   = map.new<string, bool>()
var map<string, bool> rHadHighSinceLow   = map.new<string, bool>()

// CDDO paired-array dedup — prevent consecutive same-direction pushes
var bool cddoHighSinceLastLow = true
var bool cddoLowSinceLastHigh = true

// No-crossing validation — track max high / min low between chart pivot pushes
var map<string, float> trackMaxH    = map.new<string, float>()
var map<string, float> trackMinL    = map.new<string, float>()
var map<string, float> betweenMaxH  = map.new<string, float>()
var map<string, float> betweenMinL  = map.new<string, float>()

// Ref sampling at chart pivot times — eliminates independent ref pivot misalignment
var map<string, float> refMaxSincePush = map.new<string, float>()
var map<string, float> refMinSincePush = map.new<string, float>()
var map<string, float> refAtLastPH     = map.new<string, float>()
var map<string, float> refAtPrevPH     = map.new<string, float>()
var map<string, float> refAtLastPL     = map.new<string, float>()
var map<string, float> refAtPrevPL     = map.new<string, float>()
var array<int>          smtLastFireBars = array.new_int(2, na)

float smtTrendEma      = ta.ema(close, smtTrendEmaLen)
float smtTrendSlope    = smtTrendEma - smtTrendEma[smtSlopeLen]
float smtATR           = ta.atr(14)
float smtMinSwingAbs   = smtMinATRSwing * smtATR
float smtPullbackThr   = smtATR * 0.3

// Continuous pullback depth tracking — fallback when CloseBreak low doesn’t fire
var map<string, float> minSinceHigh = map.new<string, float>()
var map<string, float> maxSinceLow  = map.new<string, float>()
bool  smtBearTrendOK   = not useSMTTrendFilter or close < smtTrendEma
bool  smtBullTrendOK   = not useSMTTrendFilter or close > smtTrendEma
bool  smtBearSlopeOK   = not useSMTSlopeFilter or smtTrendSlope < 0
bool  smtBullSlopeOK   = not useSMTSlopeFilter or smtTrendSlope > 0
bool  smtBearBreakOK   = not requireSMTBreak or close < ta.lowest(low[1], smtBreakLen)
bool  smtBullBreakOK   = not requireSMTBreak or close > ta.highest(high[1], smtBreakLen)

if barstate.isnew
    map.clear(dedupSeenBar)

f_remove_active_index(int idx) =>
    int activeCount = array.size(activeSignals)
    if activeCount > 0
        for i = activeCount - 1 to 0
            if array.get(activeSignals, i) == idx
                array.remove(activeSignals, i)
                break

f_bubble_key(int barIdx, bool isBear) =>
    str.tostring(barIdx) + (isBear ? '_B' : '_U')

f_dedup_tick_key(string bubbleKey, string shortSym) =>
    bubbleKey + '_' + shortSym

f_bubble_color(bool isBear) =>
    isBear ? bearColor : bullColor

f_bubble_text_color(bool isBear) =>
    color.new(color.white, color.t(isBear ? bearColor : bullColor))

f_bubble_style(bool isBear) =>
    isBear ? label.style_label_down : label.style_label_up

f_compose_label_text(SMTSignal sig) =>
    sig.hasSMT and sig.hasCDDO ? sig.smtText + '\n' + sig.cddoText : sig.hasSMT ? sig.smtText : sig.cddoText

f_signal_y(SMTSignal sig) =>
    sig.hasSMT and not na(sig.smtPivotPrice) ? sig.smtPivotPrice : sig.cddoPivotPrice

f_refresh_signal_visual(int idx) =>
    SMTSignal sig = array.get(signals, idx)
    if not sig.removed
        color activeColor = f_bubble_color(sig.isBear)
        color activeTextColor = f_bubble_text_color(sig.isBear)
        if not na(sig.lbl)
            label.set_text(sig.lbl, f_compose_label_text(sig))
            label.set_x(sig.lbl, sig.barIdx)
            float y = f_signal_y(sig)
            if not na(y)
                label.set_y(sig.lbl, y)
            label.set_style(sig.lbl, f_bubble_style(sig.isBear))
            label.set_size(sig.lbl, resolvedLblSize)
            if sig.invalidated
                label.set_color(sig.lbl, invalidColor)
                label.set_textcolor(sig.lbl, fadedText)
            else
                label.set_color(sig.lbl, activeColor)
                label.set_textcolor(sig.lbl, activeTextColor)
        if not na(sig.ln)
            if sig.invalidated
                line.set_color(sig.ln, invalidColor)
            else
                line.set_color(sig.ln, activeColor)

f_get_or_create_signal(string sigKey, int barIdx, float y, bool isBear) =>
    int idx = na
    if signalIdxKey.contains(sigKey)
        idx := signalIdxKey.get(sigKey)
    else
        label lbl = label.new(barIdx, y, '',
             color=f_bubble_color(isBear), style=f_bubble_style(isBear),
             textcolor=f_bubble_text_color(isBear), size=resolvedLblSize)
        signals.push(SMTSignal.new(barIdx, y, isBear, '', 0, lbl, na, false, false, false, '', '', na, na, false, false, false))
        idx := array.size(signals) - 1
        signalIdxKey.put(sigKey, idx)
        array.push(signalOrder, idx)
        array.push(activeSignals, idx)
    idx

f_register_cddo(int barIdx, float pivotPrice, bool isBear, string cddoText) =>
    string sigKey = f_bubble_key(barIdx, isBear)
    int idx = f_get_or_create_signal(sigKey, barIdx, pivotPrice, isBear)
    SMTSignal sig = array.get(signals, idx)
    if not sig.removed
        sig.barIdx := barIdx
        sig.isBear := isBear
        sig.hasCDDO := true
        sig.cddoText := cddoText
        sig.cddoPivotPrice := pivotPrice
        sig.cddoInvalidated := false
        if not sig.hasSMT
            sig.pivotPrice := pivotPrice
        sig.invalidated := (sig.hasSMT and sig.smtInvalidated) or (sig.hasCDDO and sig.cddoInvalidated)
        array.set(signals, idx, sig)
        f_refresh_signal_visual(idx)

// ████████████████████████████████████████████████████████████████████████
// CORE FUNCTIONS
// ████████████████████████████████████████████████████████████████████████
f_updatePivots(string key, float cPH, float cPL, float rPH, float rPL) =>
    int pivotBar = bar_index
    // ── Determine ref raw H/L from key prefix (access script-level vars) ──
    string _pfx = str.substring(key, 0, 1)
    float _rawRefH = _pfx == 'A' ? ref1H : _pfx == 'B' ? ref2H : ref3H
    float _rawRefL = _pfx == 'A' ? ref1L : _pfx == 'B' ? ref2L : ref3L
    // ── Track running chart max-high and min-low between pivot pushes ──
    float curMaxH = trackMaxH.contains(key) ? math.max(nz(trackMaxH.get(key), high), high) : high
    trackMaxH.put(key, curMaxH)
    float curMinL = trackMinL.contains(key) ? math.min(nz(trackMinL.get(key), low), low) : low
    trackMinL.put(key, curMinL)
    // ── Track ref running max-high (reset at chart LOW breakout) ──
    float _refH = nz(_rawRefH, high)
    float _refL = nz(_rawRefL, low)
    float curRefMax = refMaxSincePush.contains(key) ? math.max(nz(refMaxSincePush.get(key), _refH), _refH) : _refH
    refMaxSincePush.put(key, curRefMax)
    // ── Track ref running min-low (reset at chart HIGH breakout) ──
    float curRefMin = refMinSincePush.contains(key) ? math.min(nz(refMinSincePush.get(key), _refL), _refL) : _refL
    refMinSincePush.put(key, curRefMin)
    // Track pullback depth for push fallback
    float _msH = minSinceHigh.contains(key) ? math.min(nz(minSinceHigh.get(key), low), low) : low
    minSinceHigh.put(key, _msH)
    float _msL = maxSinceLow.contains(key) ? math.max(nz(maxSinceLow.get(key), high), high) : high
    maxSinceLow.put(key, _msL)
    // Chart highs: push if CloseBreak low fired OR meaningful pullback depth
    if not na(cPH)
        bool hasLowFlag = hadLowSinceHigh.contains(key) ? hadLowSinceHigh.get(key) : false
        float storedLastPH = lastPH.contains(key) ? lastPH.get(key) : na
        bool depthPullback = not na(storedLastPH) and (_msH < storedLastPH - smtPullbackThr)
        bool shouldPush = hasLowFlag or depthPullback
        if shouldPush and not na(storedLastPH)
            betweenMaxH.put(key, trackMaxH.get(key))
            trackMaxH.put(key, cPH)
            prevPH.put(key, storedLastPH)
            prevPHi.put(key, lastPHi.get(key))
            refAtPrevPH.put(key, refAtLastPH.contains(key) ? refAtLastPH.get(key) : na)
            hadLowSinceHigh.put(key, false)
            refMaxSincePush.put(key, _refH)
        refAtLastPH.put(key, refMaxSincePush.get(key))
        lastPH.put(key, cPH)
        lastPHi.put(key, pivotBar)
        hadHighSinceLow.put(key, true)
        minSinceHigh.put(key, low)
        refMinSincePush.put(key, _refL)
    // Chart lows: push if CloseBreak high fired OR meaningful rally depth
    if not na(cPL)
        bool hasHighFlag = hadHighSinceLow.contains(key) ? hadHighSinceLow.get(key) : false
        float storedLastPL = lastPL.contains(key) ? lastPL.get(key) : na
        bool depthRally = not na(storedLastPL) and (_msL > storedLastPL + smtPullbackThr)
        bool shouldPushL = hasHighFlag or depthRally
        if shouldPushL and not na(storedLastPL)
            betweenMinL.put(key, trackMinL.get(key))
            trackMinL.put(key, cPL)
            prevPL.put(key, storedLastPL)
            prevPLi.put(key, lastPLi.get(key))
            refAtPrevPL.put(key, refAtLastPL.contains(key) ? refAtLastPL.get(key) : na)
            hadHighSinceLow.put(key, false)
            refMinSincePush.put(key, _refL)
        refAtLastPL.put(key, refMinSincePush.get(key))
        lastPL.put(key, cPL)
        lastPLi.put(key, pivotBar)
        hadLowSinceHigh.put(key, true)
        maxSinceLow.put(key, high)
        refMaxSincePush.put(key, _refH)


f_checkSMT(string key, string shortSym, int pLen, float cPH, float cPL, float rPH, float rPL) =>
    bool smtBarConfirmed = not waitForClose or barstate.isconfirmed
    bool newChartHigh = not na(cPH)
    bool newChartLow  = not na(cPL)
    bool newRefHigh   = not na(rPH)
    bool newRefLow    = not na(rPL)

    if smtBarConfirmed
        // BEARISH SMT: chart + ref make diverging highs (sampled at chart pivot times)
        if newChartHigh
            float cLPH = lastPH.get(key),  float cPPH = prevPH.get(key)
            int   cLPHi = lastPHi.get(key), int cPPHi = prevPHi.get(key)
            float rLPH = refAtLastPH.contains(key) ? refAtLastPH.get(key) : na
            float rPPH = refAtPrevPH.contains(key) ? refAtPrevPH.get(key) : na
            if not na(cLPH) and not na(cPPH) and not na(rLPH) and not na(rPPH) and not na(cLPHi) and not na(cPPHi)
                bool bearStruct = (cLPH > cPPH and rLPH < rPPH) or (cLPH < cPPH and rLPH > rPPH)
                float bearSwingAbs = math.abs(cLPH - cPPH)
                bool smtBearSwingOK = not useSMTATRSwingFilter or bearSwingAbs >= smtMinSwingAbs
                int lastSMTBearFireBar = array.get(smtLastFireBars, 0)
                bool smtBearCooldownOK = smtCooldownBars == 0 or na(lastSMTBearFireBar) or (bar_index - lastSMTBearFireBar) >= smtCooldownBars
                // No-crossing: reject if any candle between the two chart pivots exceeds both
                float btwMaxH = betweenMaxH.contains(key) ? nz(betweenMaxH.get(key), cLPH) : cLPH
                bool bearNoCross = btwMaxH <= math.max(cLPH, cPPH)
                if bearStruct and smtBearTrendOK and smtBearSlopeOK and smtBearBreakOK and smtBearSwingOK and smtBearCooldownOK
                    string dk = f_bubble_key(cLPHi, true)
                    string tickKey = f_dedup_tick_key(dk, shortSym)
                    int hits = dedupCount.contains(dk) ? nz(dedupCount.get(dk)) : 0
                    bool countedThisBar = dedupSeenBar.contains(tickKey) and dedupSeenBar.get(tickKey) == bar_index
                    if not countedThisBar
                        hits += 1
                        dedupCount.put(dk, hits)
                        dedupSeenBar.put(tickKey, bar_index)

                    string firstSym = dedupSyms.contains(dk) ? dedupSyms.get(dk) : shortSym
                    if not dedupSyms.contains(dk)
                        dedupSyms.put(dk, shortSym)

                    string stars = hits >= 4 ? ' ★★★' : hits >= 3 ? ' ★★' : hits >= 2 ? ' ★' : ''
                    string smtText = firstSym + stars

                    if hits >= smtMinConfirmations
                        int idx = f_get_or_create_signal(dk, cLPHi, cLPH, true)
                        SMTSignal sig = array.get(signals, idx)
                        if not sig.removed
                            sig.barIdx := cLPHi
                            sig.pivotPrice := cLPH
                            sig.isBear := true
                            sig.symName := shortSym
                            sig.pivotLen := pLen
                            sig.hasSMT := true
                            sig.smtText := smtText
                            sig.smtPivotPrice := cLPH
                            sig.smtInvalidated := false
                            if na(sig.ln) and not na(cPPHi)
                                sig.ln := line.new(cPPHi, cPPH, cLPHi, cLPH, xloc=xloc.bar_index,
                                     color=bearColor, style=bearStyleEnum, width=bearLineWidth)
                            sig.invalidated := (sig.hasSMT and sig.smtInvalidated) or (sig.hasCDDO and sig.cddoInvalidated)
                            array.set(signals, idx, sig)
                            f_refresh_signal_visual(idx)
                            array.set(smtLastFireBars, 0, bar_index)
                            if hits == smtMinConfirmations
                                array.push(smtHistory, idx)
                                if array.size(smtHistory) > 300
                                    array.shift(smtHistory)

        // BULLISH SMT: chart + ref make diverging lows (sampled at chart pivot times)
        if newChartLow
            float cLPL = lastPL.get(key),  float cPPL = prevPL.get(key)
            int   cLPLi = lastPLi.get(key), int cPPLi = prevPLi.get(key)
            float rLPL = refAtLastPL.contains(key) ? refAtLastPL.get(key) : na
            float rPPL = refAtPrevPL.contains(key) ? refAtPrevPL.get(key) : na
            if not na(cLPL) and not na(cPPL) and not na(rLPL) and not na(rPPL) and not na(cLPLi) and not na(cPPLi)
                bool bullStruct = (cLPL < cPPL and rLPL > rPPL) or (cLPL > cPPL and rLPL < rPPL)
                float bullSwingAbs = math.abs(cLPL - cPPL)
                bool smtBullSwingOK = not useSMTATRSwingFilter or bullSwingAbs >= smtMinSwingAbs
                int lastSMTBullFireBar = array.get(smtLastFireBars, 1)
                bool smtBullCooldownOK = smtCooldownBars == 0 or na(lastSMTBullFireBar) or (bar_index - lastSMTBullFireBar) >= smtCooldownBars
                // No-crossing: reject if any candle between the two chart pivots falls below both
                float btwMinL = betweenMinL.contains(key) ? nz(betweenMinL.get(key), cLPL) : cLPL
                bool bullNoCross = btwMinL >= math.min(cLPL, cPPL)
                if bullStruct and smtBullTrendOK and smtBullSlopeOK and smtBullBreakOK and smtBullSwingOK and smtBullCooldownOK
                    string dk = f_bubble_key(cLPLi, false)
                    string tickKey = f_dedup_tick_key(dk, shortSym)
                    int hits = dedupCount.contains(dk) ? nz(dedupCount.get(dk)) : 0
                    bool countedThisBar = dedupSeenBar.contains(tickKey) and dedupSeenBar.get(tickKey) == bar_index
                    if not countedThisBar
                        hits += 1
                        dedupCount.put(dk, hits)
                        dedupSeenBar.put(tickKey, bar_index)

                    string firstSym = dedupSyms.contains(dk) ? dedupSyms.get(dk) : shortSym
                    if not dedupSyms.contains(dk)
                        dedupSyms.put(dk, shortSym)

                    string stars = hits >= 4 ? ' ★★★' : hits >= 3 ? ' ★★' : hits >= 2 ? ' ★' : ''
                    string smtText = firstSym + stars

                    if hits >= smtMinConfirmations
                        int idx = f_get_or_create_signal(dk, cLPLi, cLPL, false)
                        SMTSignal sig = array.get(signals, idx)
                        if not sig.removed
                            sig.barIdx := cLPLi
                            sig.pivotPrice := cLPL
                            sig.isBear := false
                            sig.symName := shortSym
                            sig.pivotLen := pLen
                            sig.hasSMT := true
                            sig.smtText := smtText
                            sig.smtPivotPrice := cLPL
                            sig.smtInvalidated := false
                            if na(sig.ln) and not na(cPPLi)
                                sig.ln := line.new(cPPLi, cPPL, cLPLi, cLPL, xloc=xloc.bar_index,
                                     color=bullColor, style=bullStyleEnum, width=bullLineWidth)
                            sig.invalidated := (sig.hasSMT and sig.smtInvalidated) or (sig.hasCDDO and sig.cddoInvalidated)
                            array.set(signals, idx, sig)
                            f_refresh_signal_visual(idx)
                            array.set(smtLastFireBars, 1, bar_index)
                            if hits == smtMinConfirmations
                                array.push(smtHistory, idx)
                                if array.size(smtHistory) > 300
                                    array.shift(smtHistory)

f_process(string key, string shortSym, int pLen, float cPH, float cPL, float rPH, float rPL) =>
    f_updatePivots(key, cPH, cPL, rPH, rPL)
    f_checkSMT(key, shortSym, pLen, cPH, cPL, rPH, rPL)

// ████████████████████████████████████████████████████████████████████████
// PROCESS ALL COMBINATIONS — guarded by symbol + range toggles
// ████████████████████████████████████████████████████████████████████████

// ─── SYMBOL 1 ───
if sym1On
    if range1On
        f_process('A1', sym1Short, 2,  cPH_2,  cPL_2,  r1PH_2,  r1PL_2)
        f_process('A2', sym1Short, 3,  cPH_3,  cPL_3,  r1PH_3,  r1PL_3)
        f_process('A3', sym1Short, 5,  cPH_5,  cPL_5,  r1PH_5,  r1PL_5)
        f_process('A4', sym1Short, 6,  cPH_6,  cPL_6,  r1PH_6,  r1PL_6)
        f_process('A5', sym1Short, 8,  cPH_8,  cPL_8,  r1PH_8,  r1PL_8)
        f_process('A6', sym1Short, 10, cPH_10, cPL_10, r1PH_10, r1PL_10)
    if range2On
        f_process('A7',  sym1Short, 12, cPH_12, cPL_12, r1PH_12, r1PL_12)
        f_process('A8',  sym1Short, 14, cPH_14, cPL_14, r1PH_14, r1PL_14)
        f_process('A9',  sym1Short, 17, cPH_17, cPL_17, r1PH_17, r1PL_17)
        f_process('A10', sym1Short, 20, cPH_20, cPL_20, r1PH_20, r1PL_20)
        f_process('A11', sym1Short, 22, cPH_22, cPL_22, r1PH_22, r1PL_22)
        f_process('A12', sym1Short, 25, cPH_25, cPL_25, r1PH_25, r1PL_25)
    if range3On
        f_process('A13', sym1Short, 30, cPH_30, cPL_30, r1PH_30, r1PL_30)
        f_process('A14', sym1Short, 35, cPH_35, cPL_35, r1PH_35, r1PL_35)
        f_process('A15', sym1Short, 40, cPH_40, cPL_40, r1PH_40, r1PL_40)
        f_process('A16', sym1Short, 45, cPH_45, cPL_45, r1PH_45, r1PL_45)
        f_process('A17', sym1Short, 50, cPH_50, cPL_50, r1PH_50, r1PL_50)
        f_process('A18', sym1Short, 60, cPH_60, cPL_60, r1PH_60, r1PL_60)

// ─── SYMBOL 2 ───
if sym2On
    if range1On
        f_process('B1', sym2Short, 2,  cPH_2,  cPL_2,  r2PH_2,  r2PL_2)
        f_process('B2', sym2Short, 3,  cPH_3,  cPL_3,  r2PH_3,  r2PL_3)
        f_process('B3', sym2Short, 5,  cPH_5,  cPL_5,  r2PH_5,  r2PL_5)
        f_process('B4', sym2Short, 6,  cPH_6,  cPL_6,  r2PH_6,  r2PL_6)
        f_process('B5', sym2Short, 8,  cPH_8,  cPL_8,  r2PH_8,  r2PL_8)
        f_process('B6', sym2Short, 10, cPH_10, cPL_10, r2PH_10, r2PL_10)
    if range2On
        f_process('B7',  sym2Short, 12, cPH_12, cPL_12, r2PH_12, r2PL_12)
        f_process('B8',  sym2Short, 14, cPH_14, cPL_14, r2PH_14, r2PL_14)
        f_process('B9',  sym2Short, 17, cPH_17, cPL_17, r2PH_17, r2PL_17)
        f_process('B10', sym2Short, 20, cPH_20, cPL_20, r2PH_20, r2PL_20)
        f_process('B11', sym2Short, 22, cPH_22, cPL_22, r2PH_22, r2PL_22)
        f_process('B12', sym2Short, 25, cPH_25, cPL_25, r2PH_25, r2PL_25)
    if range3On
        f_process('B13', sym2Short, 30, cPH_30, cPL_30, r2PH_30, r2PL_30)
        f_process('B14', sym2Short, 35, cPH_35, cPL_35, r2PH_35, r2PL_35)
        f_process('B15', sym2Short, 40, cPH_40, cPL_40, r2PH_40, r2PL_40)
        f_process('B16', sym2Short, 45, cPH_45, cPL_45, r2PH_45, r2PL_45)
        f_process('B17', sym2Short, 50, cPH_50, cPL_50, r2PH_50, r2PL_50)
        f_process('B18', sym2Short, 60, cPH_60, cPL_60, r2PH_60, r2PL_60)

// ─── SYMBOL 3 ───
if sym3On
    if range1On
        f_process('C1', sym3Short, 2,  cPH_2,  cPL_2,  r3PH_2,  r3PL_2)
        f_process('C2', sym3Short, 3,  cPH_3,  cPL_3,  r3PH_3,  r3PL_3)
        f_process('C3', sym3Short, 5,  cPH_5,  cPL_5,  r3PH_5,  r3PL_5)
        f_process('C4', sym3Short, 6,  cPH_6,  cPL_6,  r3PH_6,  r3PL_6)
        f_process('C5', sym3Short, 8,  cPH_8,  cPL_8,  r3PH_8,  r3PL_8)
        f_process('C6', sym3Short, 10, cPH_10, cPL_10, r3PH_10, r3PL_10)
    if range2On
        f_process('C7',  sym3Short, 12, cPH_12, cPL_12, r3PH_12, r3PL_12)
        f_process('C8',  sym3Short, 14, cPH_14, cPL_14, r3PH_14, r3PL_14)
        f_process('C9',  sym3Short, 17, cPH_17, cPL_17, r3PH_17, r3PL_17)
        f_process('C10', sym3Short, 20, cPH_20, cPL_20, r3PH_20, r3PL_20)
        f_process('C11', sym3Short, 22, cPH_22, cPL_22, r3PH_22, r3PL_22)
        f_process('C12', sym3Short, 25, cPH_25, cPL_25, r3PH_25, r3PL_25)
    if range3On
        f_process('C13', sym3Short, 30, cPH_30, cPL_30, r3PH_30, r3PL_30)
        f_process('C14', sym3Short, 35, cPH_35, cPL_35, r3PH_35, r3PL_35)
        f_process('C15', sym3Short, 40, cPH_40, cPL_40, r3PH_40, r3PL_40)
        f_process('C16', sym3Short, 45, cPH_45, cPL_45, r3PH_45, r3PL_45)
        f_process('C17', sym3Short, 50, cPH_50, cPL_50, r3PH_50, r3PL_50)
        f_process('C18', sym3Short, 60, cPH_60, cPL_60, r3PH_60, r3PL_60)

// ████████████████████████████████████████████████████████████████████████
// CDDO + KVO DIVERGENCE ENGINE
// ████████████████████████████████████████████████████████████████████████
float atr14          = ta.atr(14)
float minATRSwingVal = minATRSwing * atr14

float volSMA       = ta.sma(volume, volLookbackLen)
float volThreshold = volSMA * volMultiplier
float surgeThresh  = volSMA * surgeMult
float _pivotVol    = volume
float _pivotVolP1  = nz(volume[1])
float _pivotVolM1  = _pivotVol
float _maxPivotVol = math.max(_pivotVol, math.max(_pivotVolP1, _pivotVolM1))
bool  volOKatPivot = not useVolumeFilter or _maxPivotVol >= volThreshold
bool  volSurgeOK   = _maxPivotVol >= surgeThresh

bool bullCandleOK = not useCandleConfirm or f_bullish_candle(0)
bool bearCandleOK = not useCandleConfirm or f_bearish_candle(0)

float trendEma     = needEma ? ta.ema(close, emaLen) : na
float emaSlope     = needEma ? trendEma - trendEma[slopeLen] : na
bool  emaSlopeUp   = needEma ? emaSlope > 0 : false
bool  emaSlopeDown = needEma ? emaSlope < 0 : false

float barRange = math.max(high - low, syminfo.mintick)
float deltaRaw = switch srcMode
    'Body Pressure'  => volume * ((close - open) / barRange)
    'Close Location' => volume * ((((close - low) / barRange) * 2.0) - 1.0)
    => close > open ? volume : close < open ? -volume : 0.0

bool newDay = ta.change(time('D')) != 0
var float cvd = 0.0
if resetDaily and newDay
    cvd := deltaRaw
else
    cvd += deltaRaw

float cddoBase     = useCVD ? cvd : deltaRaw
float cddoSmoothed = ta.ema(cddoBase, smoothLen)
float cddoMean     = ta.sma(cddoSmoothed, zLenCDDO)
float cddoStdev    = ta.stdev(cddoSmoothed, zLenCDDO)
float cddoZ        = cddoStdev != 0 ? (cddoSmoothed - cddoMean) / cddoStdev : 0.0

float sv        = ta.change(hlc3) >= 0 ? volume : -volume
float kvo       = ta.ema(sv, kvoFast) - ta.ema(sv, kvoSlow)
float kvoSignal = ta.ema(kvo, kvoSignalLen)
float kvoMean   = ta.sma(kvo, zLenKVO)
float kvoStdev  = ta.stdev(kvo, zLenKVO)
float kvoZ      = kvoStdev != 0 ? (kvo - kvoMean) / kvoStdev : 0.0

bool  engineTight = math.abs(cddoZ - kvoZ) < engineSpreadMax
float hybridOsc   = cddoZ * blendWeightCDDO + kvoZ * blendWeightKVO

float pHigh = useCloseBreak and close > ta.highest(high[1], pivotLen) ? high : na
float pLow  = useCloseBreak and close < ta.lowest(low[1], pivotLen) ? low : na
float oHigh = useCloseBreak and hybridOsc > ta.highest(hybridOsc[1], pivotLen) ? hybridOsc : na
float oLow  = useCloseBreak and hybridOsc < ta.lowest(hybridOsc[1], pivotLen) ? hybridOsc : na

bool hasPriceHigh = not na(pHigh)
bool hasPriceLow  = not na(pLow)
bool hasOscHigh   = not na(oHigh)
bool hasOscLow    = not na(oLow)

int cddoPivotBar = bar_index

var int   lastSeenPriceLowBar  = na
var float lastSeenPriceLowVal  = na
var int   lastSeenPriceHighBar = na
var float lastSeenPriceHighVal = na
var int   lastSeenOscLowBar    = na
var float lastSeenOscLowVal    = na
var int   lastSeenOscHighBar   = na
var float lastSeenOscHighVal   = na

if hasPriceLow
    lastSeenPriceLowBar := cddoPivotBar
    lastSeenPriceLowVal := pLow

if hasPriceHigh
    lastSeenPriceHighBar := cddoPivotBar
    lastSeenPriceHighVal := pHigh

if hasOscLow
    lastSeenOscLowBar := cddoPivotBar
    lastSeenOscLowVal := oLow

if hasOscHigh
    lastSeenOscHighBar := cddoPivotBar
    lastSeenOscHighVal := oHigh

var array<int>   lowBars     = array.new_int()
var array<float> lowPriceRaw = array.new_float()
var array<float> lowOscRaw   = array.new_float()
var array<int>   highBars     = array.new_int()
var array<float> highPriceRaw = array.new_float()
var array<float> highOscRaw   = array.new_float()

// ── Low pair dedup: push new entry only if a high pair was stored since last low pair ──
bool wantLowPair = false
int  lowPairBar  = na
float lowPairP   = na
float lowPairO   = na

if hasPriceLow and not na(lastSeenOscLowBar) and math.abs(cddoPivotBar - lastSeenOscLowBar) <= pairTolerance
    wantLowPair := true
    lowPairBar  := cddoPivotBar
    lowPairP    := pLow
    lowPairO    := lastSeenOscLowVal

if not wantLowPair and hasOscLow and not na(lastSeenPriceLowBar) and math.abs(cddoPivotBar - lastSeenPriceLowBar) <= pairTolerance
    wantLowPair := true
    lowPairBar  := lastSeenPriceLowBar
    lowPairP    := lastSeenPriceLowVal
    lowPairO    := oLow

if wantLowPair
    int lowSzNow = array.size(lowBars)
    if cddoHighSinceLastLow or lowSzNow == 0
        f_push_pair(lowBars, lowPriceRaw, lowOscRaw, lowPairBar, lowPairP, lowPairO, maxStoredPairs)
    else if lowSzNow > 0
        int li = lowSzNow - 1
        if array.get(lowBars, li) != lowPairBar
            array.set(lowBars, li, lowPairBar)
            array.set(lowPriceRaw, li, lowPairP)
            array.set(lowOscRaw, li, lowPairO)
    cddoHighSinceLastLow := false
    cddoLowSinceLastHigh := true

// ── High pair dedup: push new entry only if a low pair was stored since last high pair ──
bool wantHighPair = false
int  highPairBar  = na
float highPairP   = na
float highPairO   = na

if hasPriceHigh and not na(lastSeenOscHighBar) and math.abs(cddoPivotBar - lastSeenOscHighBar) <= pairTolerance
    wantHighPair := true
    highPairBar  := cddoPivotBar
    highPairP    := pHigh
    highPairO    := lastSeenOscHighVal

if not wantHighPair and hasOscHigh and not na(lastSeenPriceHighBar) and math.abs(cddoPivotBar - lastSeenPriceHighBar) <= pairTolerance
    wantHighPair := true
    highPairBar  := lastSeenPriceHighBar
    highPairP    := lastSeenPriceHighVal
    highPairO    := oHigh

if wantHighPair
    int highSzNow = array.size(highBars)
    if cddoLowSinceLastHigh or highSzNow == 0
        f_push_pair(highBars, highPriceRaw, highOscRaw, highPairBar, highPairP, highPairO, maxStoredPairs)
    else if highSzNow > 0
        int hi = highSzNow - 1
        if array.get(highBars, hi) != highPairBar
            array.set(highBars, hi, highPairBar)
            array.set(highPriceRaw, hi, highPairP)
            array.set(highOscRaw, hi, highPairO)
    cddoLowSinceLastHigh := false
    cddoHighSinceLastLow := true

float cddoZPrev = cddoZ[1]
float kvoZPrev  = kvoZ[1]
bool bullConfirmOK = cddoZ > cddoZPrev and kvoZ > kvoZPrev and kvo > kvoSignal
bool bearConfirmOK = cddoZ < cddoZPrev and kvoZ < kvoZPrev and kvo < kvoSignal
bool bullTrendOK = not useTrendFilter or close > trendEma
bool bearTrendOK = not useTrendFilter or close < trendEma

var bool  regBullSignal   = false
var bool  hidBullSignal   = false
var int   regBullCurBar   = na
var float regBullCurPrice = na
var int   regBullGrade    = 0
var int   hidBullCurBar   = na
var float hidBullCurPrice = na
var int   hidBullGrade    = 0
var bool  regBearSignal   = false
var bool  hidBearSignal   = false
var int   regBearCurBar   = na
var float regBearCurPrice = na
var int   regBearGrade    = 0
var int   hidBearCurBar   = na
var float hidBearCurPrice = na
var int   hidBearGrade    = 0

regBullSignal := false
hidBullSignal := false
regBearSignal := false
hidBearSignal := false

int bullStaticGrade = (volOKatPivot ? 1 : 0) + (bullConfirmOK ? 1 : 0) + (volSurgeOK ? 1 : 0) + (bullCandleOK ? 1 : 0) + (engineTight ? 1 : 0) + ((not useSlopeAlign or emaSlopeUp) ? 1 : 0)
int bearStaticGrade = (volOKatPivot ? 1 : 0) + (bearConfirmOK ? 1 : 0) + (volSurgeOK ? 1 : 0) + (bearCandleOK ? 1 : 0) + (engineTight ? 1 : 0) + ((not useSlopeAlign or emaSlopeDown) ? 1 : 0)

int lowSz = array.size(lowBars)
if lowSz >= 2
    int   curIdxLow = lowSz - 1
    int   curLowBar = array.get(lowBars, curIdxLow)
    float curLowPrice = array.get(lowPriceRaw, curIdxLow)
    float curLowOsc = array.get(lowOscRaw, curIdxLow)
    float bestRegBullScore = na
    float bestHidBullScore = na

    int startLowIdx = math.max(0, lowSz - 1 - scanBackPairs)
    if bullTrendOK
        for i = startLowIdx to curIdxLow - 1
            int prevLowBar = array.get(lowBars, i)
            int barSpan = curLowBar - prevLowBar
            if barSpan < minPivotSpacing
                continue

            float prevLowOsc = array.get(lowOscRaw, i)
            float oscDelta = math.abs(curLowOsc - prevLowOsc)
            if oscDelta < minOscSwing
                continue

            float prevLowPrice = array.get(lowPriceRaw, i)
            bool isRegBullStructure = f_lower_or_equal(curLowPrice, prevLowPrice, priceTol) and f_higher_or_equal(curLowOsc, prevLowOsc, oscTolerance)
            bool isHidBullStructure = f_higher_or_equal(curLowPrice, prevLowPrice, priceTol) and f_lower_or_equal(curLowOsc, prevLowOsc, oscTolerance)
            if not isRegBullStructure and not isHidBullStructure
                continue

            float priceDelta = math.abs(curLowPrice - prevLowPrice)
            bool chkATR = not useATRSwingFilter or priceDelta >= minATRSwingVal
            bool chkZSwing = oscDelta >= minZSwing
            bool chkExtreme = not useExtremeFilter or (curLowOsc <= negExtremeLevel or prevLowOsc <= negExtremeLevel)
            bool chkDepth = barSpan >= minSwingBars

            int grade = bullStaticGrade + (chkATR ? 1 : 0) + (chkZSwing ? 1 : 0) + (chkExtreme ? 1 : 0) + (chkDepth ? 1 : 0)
            if grade < GRADE_MODERATE
                continue

            float score = priceDelta + oscDelta
            if isRegBullStructure and (na(bestRegBullScore) or score > bestRegBullScore)
                bestRegBullScore := score
                regBullSignal := true
                regBullCurBar := curLowBar
                regBullCurPrice := curLowPrice
                regBullGrade := grade
            if isHidBullStructure and (na(bestHidBullScore) or score > bestHidBullScore)
                bestHidBullScore := score
                hidBullSignal := true
                hidBullCurBar := curLowBar
                hidBullCurPrice := curLowPrice
                hidBullGrade := grade

int highSz = array.size(highBars)
if highSz >= 2
    int   curIdxHigh = highSz - 1
    int   curHighBar = array.get(highBars, curIdxHigh)
    float curHighPrice = array.get(highPriceRaw, curIdxHigh)
    float curHighOsc = array.get(highOscRaw, curIdxHigh)
    float bestRegBearScore = na
    float bestHidBearScore = na

    int startHighIdx = math.max(0, highSz - 1 - scanBackPairs)
    if bearTrendOK
        for i = startHighIdx to curIdxHigh - 1
            int prevHighBar = array.get(highBars, i)
            int barSpan = curHighBar - prevHighBar
            if barSpan < minPivotSpacing
                continue

            float prevHighOsc = array.get(highOscRaw, i)
            float oscDelta = math.abs(curHighOsc - prevHighOsc)
            if oscDelta < minOscSwing
                continue

            float prevHighPrice = array.get(highPriceRaw, i)
            bool isRegBearStructure = f_higher_or_equal(curHighPrice, prevHighPrice, priceTol) and f_lower_or_equal(curHighOsc, prevHighOsc, oscTolerance)
            bool isHidBearStructure = f_lower_or_equal(curHighPrice, prevHighPrice, priceTol) and f_higher_or_equal(curHighOsc, prevHighOsc, oscTolerance)
            if not isRegBearStructure and not isHidBearStructure
                continue

            float priceDelta = math.abs(curHighPrice - prevHighPrice)
            bool chkATR = not useATRSwingFilter or priceDelta >= minATRSwingVal
            bool chkZSwing = oscDelta >= minZSwing
            bool chkExtreme = not useExtremeFilter or (curHighOsc >= extremeLevel or prevHighOsc >= extremeLevel)
            bool chkDepth = barSpan >= minSwingBars

            int grade = bearStaticGrade + (chkATR ? 1 : 0) + (chkZSwing ? 1 : 0) + (chkExtreme ? 1 : 0) + (chkDepth ? 1 : 0)
            if grade < GRADE_MODERATE
                continue

            float score = priceDelta + oscDelta
            if isRegBearStructure and (na(bestRegBearScore) or score > bestRegBearScore)
                bestRegBearScore := score
                regBearSignal := true
                regBearCurBar := curHighBar
                regBearCurPrice := curHighPrice
                regBearGrade := grade
            if isHidBearStructure and (na(bestHidBearScore) or score > bestHidBearScore)
                bestHidBearScore := score
                hidBearSignal := true
                hidBearCurBar := curHighBar
                hidBearCurPrice := curHighPrice
                hidBearGrade := grade

var int lastBullSignalBar = na
var int lastBearSignalBar = na
var int lastBullFireBar   = na
var int lastBearFireBar   = na

bool barConfirmed   = not waitForClose or barstate.isconfirmed
bool bullCooldownOK = signalCooldown == 0 or na(lastBullFireBar) or (bar_index - lastBullFireBar) >= signalCooldown
bool bearCooldownOK = signalCooldown == 0 or na(lastBearFireBar) or (bar_index - lastBearFireBar) >= signalCooldown
bool fireRegBull = false
bool fireHidBull = false
bool fireRegBear = false
bool fireHidBear = false

if regBullSignal and barConfirmed and (na(lastBullSignalBar) or lastBullSignalBar != regBullCurBar) and bullCooldownOK
    fireRegBull := true
    f_register_cddo(regBullCurBar, regBullCurPrice, false, 'RCDD' + f_tier_label_reg(regBullGrade))
    lastBullSignalBar := regBullCurBar
    lastBullFireBar := bar_index

if hidBullSignal and barConfirmed and (na(lastBullSignalBar) or lastBullSignalBar != hidBullCurBar) and bullCooldownOK
    fireHidBull := true
    f_register_cddo(hidBullCurBar, hidBullCurPrice, false, 'HCDD' + f_tier_label_hid(hidBullGrade))
    lastBullSignalBar := hidBullCurBar
    lastBullFireBar := bar_index

if regBearSignal and barConfirmed and (na(lastBearSignalBar) or lastBearSignalBar != regBearCurBar) and bearCooldownOK
    fireRegBear := true
    f_register_cddo(regBearCurBar, regBearCurPrice, true, 'RCDD' + f_tier_label_reg(regBearGrade))
    lastBearSignalBar := regBearCurBar
    lastBearFireBar := bar_index

if hidBearSignal and barConfirmed and (na(lastBearSignalBar) or lastBearSignalBar != hidBearCurBar) and bearCooldownOK
    fireHidBear := true
    f_register_cddo(hidBearCurBar, hidBearCurPrice, true, 'HCDD' + f_tier_label_hid(hidBearGrade))
    lastBearSignalBar := hidBearCurBar
    lastBearFireBar := bar_index

// ████████████████████████████████████████████████████████████████████████
// INVALIDATION — SMT OR CDDO invalidates merged bubble
// ████████████████████████████████████████████████████████████████████████
int activeCount = array.size(activeSignals)
if activeCount > 0
    for pos = activeCount - 1 to 0
        int idx = array.get(activeSignals, pos)
        SMTSignal sig = array.get(signals, idx)
        if sig.removed
            array.remove(activeSignals, pos)
            continue
        if sig.invalidated
            continue

        if sig.hasSMT and not sig.smtInvalidated and not na(sig.smtPivotPrice)
            bool invSMT = sig.isBear ? high > sig.smtPivotPrice : low < sig.smtPivotPrice
            if invSMT
                sig.smtInvalidated := true

        if sig.hasCDDO and not sig.cddoInvalidated and not na(sig.cddoPivotPrice)
            bool invCDDO = sig.isBear ? high > sig.cddoPivotPrice : low < sig.cddoPivotPrice
            if invCDDO
                sig.cddoInvalidated := true

        bool mergedInvalidated = (sig.hasSMT and sig.smtInvalidated) or (sig.hasCDDO and sig.cddoInvalidated)
        if mergedInvalidated and not sig.invalidated
            sig.invalidated := true
            if showInvalidated
                if not na(sig.lbl)
                    label.set_color(sig.lbl, invalidColor)
                    label.set_textcolor(sig.lbl, fadedText)
                if not na(sig.ln)
                    line.set_color(sig.ln, invalidColor)
            else
                if not na(sig.lbl)
                    label.delete(sig.lbl)
                if not na(sig.ln)
                    line.delete(sig.ln)
                sig.lbl := na
                sig.ln := na
                sig.removed := true
                array.remove(activeSignals, pos)

        array.set(signals, idx, sig)

// Cap array visuals to prevent memory issues while keeping stable indexes
while array.size(signalOrder) > 300
    int oldIdx = array.shift(signalOrder)
    SMTSignal old = array.get(signals, oldIdx)
    if not old.removed
        if not na(old.lbl)
            label.delete(old.lbl)
        if not na(old.ln)
            line.delete(old.ln)
        old.lbl := na
        old.ln := na
        old.invalidated := true
        old.smtInvalidated := old.hasSMT ? true : old.smtInvalidated
        old.cddoInvalidated := old.hasCDDO ? true : old.cddoInvalidated
        old.removed := true
        array.set(signals, oldIdx, old)
        f_remove_active_index(oldIdx)

// ████████████████████████████████████████████████████████████████████████
// ALERT CONDITIONS
// ████████████████████████████████████████████████████████████████████████
bool anyBear = false
bool anyBull = false
int smtHistCount = array.size(smtHistory)
if smtHistCount > 0
    for i = smtHistCount - 1 to 0
        int idx = array.get(smtHistory, i)
        SMTSignal newest = array.get(signals, idx)
        bool usable = newest.hasSMT and not newest.removed and not newest.invalidated and (bar_index - newest.barIdx) <= 60
        if usable
            anyBear := newest.isBear
            anyBull := not newest.isBear
            break

plotshape(anyBear, title='Bearish SMT', style=shape.triangledown, location=location.abovebar,
     color=bearColor, size=size.tiny, display=display.none)
plotshape(anyBull, title='Bullish SMT', style=shape.triangleup, location=location.belowbar,
     color=bullColor, size=size.tiny, display=display.none)

alertcondition(anyBear, title='Bearish SMT Divergence', message='Bearish SMT Divergence on {{ticker}}')
alertcondition(anyBull, title='Bullish SMT Divergence', message='Bullish SMT Divergence on {{ticker}}')
alertcondition(anyBear or anyBull, title='Any SMT Divergence', message='SMT Divergence detected on {{ticker}}')

alertcondition(fireRegBull, 'Hybrid Regular Bullish', 'Hybrid regular bullish divergence detected')
alertcondition(fireHidBull, 'Hybrid Hidden Bullish', 'Hybrid hidden bullish divergence detected')
alertcondition(fireRegBear, 'Hybrid Regular Bearish', 'Hybrid regular bearish divergence detected')
alertcondition(fireHidBear, 'Hybrid Hidden Bearish', 'Hybrid hidden bearish divergence detected')
