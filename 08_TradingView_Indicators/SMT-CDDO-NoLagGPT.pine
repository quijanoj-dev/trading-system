float r2PH_40 = need2R3 and useCloseBreak and ref2H > ta.highest(ref2H[1], 40) ? ref2H : na, float r2PL_40 = need2R3 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 40)  ? ref2L : na
float r2PH_45 = need2R3 and useCloseBreak and ref2H > ta.highest(ref2H[1], 45) ? ref2H : na, float r2PL_45 = need2R3 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 45)  ? ref2L : na
float r2PH_50 = need2R3 and useCloseBreak and ref2H > ta.highest(ref2H[1], 50) ? ref2H : na, float r2PL_50 = need2R3 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 50)  ? ref2L : na
float r2PH_60 = need2R3 and useCloseBreak and ref2H > ta.highest(ref2H[1], 60) ? ref2H : na, float r2PL_60 = need2R3 and useCloseBreak and ref2L < ta.lowest(ref2L[1], 60)  ? ref2L : na

// Ref3 swings
bool need3R1 = needR1 and sym3On, bool need3R2 = needR2 and sym3On, bool need3R3 = needR3 and sym3On
float r3PH_2  = need3R1 and useCloseBreak and ref3H > ta.highest(ref3H[1], 2)  ? ref3H : na, float r3PL_2  = need3R1 and useCloseBreak and ref3L < ta.lowest(ref3L[1], 2)   ? ref3L : na
