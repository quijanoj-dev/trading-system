bool  useCandleConfirm = input.bool(false, 'Candle Confirmation (Engulfing / Pin Bar)', group=CDDO_STRENGTH_GROUP)
float engineSpreadMax  = input.float(1.0, 'Max Engine Z-Score Spread', minval=0.1, maxval=3.0, step=0.1, group=CDDO_STRENGTH_GROUP)
bool  useSlopeAlign    = input.bool(false, 'Trend Slope Alignment', group=CDDO_STRENGTH_GROUP)
int   slopeLen         = input.int(5, 'Slope Lookback', minval=1, maxval=20, group=CDDO_STRENGTH_GROUP)

// ████████████████████████████████████████████████████████████████████████
// RESOLVED STYLES — pre-computed once (var)
// ████████████████████████████████████████████████████████████████████████
var string bullStyleEnum = switch bullLineStyle
    'Solid'  => line.style_solid
    'Dashed' => line.style_dashed
    'Dotted' => line.style_dotted
    => line.style_solid

var string bearStyleEnum = switch bearLineStyle
    'Solid'  => line.style_solid
    'Dashed' => line.style_dashed
    'Dotted' => line.style_dotted
    => line.style_solid

// PRE-COMPUTED COLORS
var float invAlpha  = color.t(invalidColor)
var color fadedText = color.new(color.white, invAlpha)

// CDDO constants and pre-computed values
var float priceTol        = priceToleranceTicks * syminfo.mintick
var float negExtremeLevel = -extremeLevel
var int   pairTolerance   = math.round(pivotLen * pivotToleranceMult)
var float blendWeightKVO  = 1.0 - blendWeightCDDO
var bool  needEma         = useTrendFilter or useSlopeAlign

var int GRADE_ELITE    = 8
var int GRADE_STRONG   = 5
var int GRADE_MODERATE = 3

var string TIER_REG_1 = ' ◆'
var string TIER_REG_2 = ' ◆◆'
var string TIER_REG_3 = ' ◆◆◆'
var string TIER_HID_1 = ' ◇'
var string TIER_HID_2 = ' ◇◇'
var string TIER_HID_3 = ' ◇◇◇'

f_higher_or_equal(float cur, float prev, float tol) =>
    cur >= prev - tol

f_lower_or_equal(float cur, float prev, float tol) =>
    cur <= prev + tol

f_push_pair(array<int> _bars, array<float> _priceRaw, array<float> _oscRaw, int _bar, float _p, float _o, int _maxSize) =>
    int sz = array.size(_bars)
    bool added = sz == 0 or array.get(_bars, sz - 1) != _bar
    if added
        array.push(_bars, _bar)
        array.push(_priceRaw, _p)
        array.push(_oscRaw, _o)
        if array.size(_bars) > _maxSize
            array.shift(_bars)
            array.shift(_priceRaw)
            array.shift(_oscRaw)
    added

f_bullish_candle(int offset) =>
    float o = open[offset], float c = close[offset]
    float h = high[offset], float l = low[offset]
    float po = open[offset + 1], float pc = close[offset + 1]
    float body = math.abs(c - o)
    float rng = math.max(h - l, syminfo.mintick)
    float lowerWick = math.min(o, c) - l
    float upperWick = h - math.max(o, c)
    bool engulfing = c > o and pc < po and c > po and o < pc
    bool hammer = lowerWick >= body * 2.0 and upperWick < body * 0.5 and body > 0
    bool pinBar = lowerWick / rng >= 0.66
    engulfing or hammer or pinBar

f_bearish_candle(int offset) =>
    float o = open[offset], float c = close[offset]
    float h = high[offset], float l = low[offset]
    float po = open[offset + 1], float pc = close[offset + 1]
    float body = math.abs(c - o)
    float rng = math.max(h - l, syminfo.mintick)
    float lowerWick = math.min(o, c) - l
    float upperWick = h - math.max(o, c)
    bool engulfing = c < o and pc > po and c < po and o > pc
    bool shootingStar = upperWick >= body * 2.0 and lowerWick < body * 0.5 and body > 0
    bool pinBar = upperWick / rng >= 0.66
    engulfing or shootingStar or pinBar

f_tier_label_reg(int grade) =>
    grade >= GRADE_ELITE ? TIER_REG_3 : grade >= GRADE_STRONG ? TIER_REG_2 : TIER_REG_1

f_tier_label_hid(int grade) =>
    grade >= GRADE_ELITE ? TIER_HID_3 : grade >= GRADE_STRONG ? TIER_HID_2 : TIER_HID_1

// PRE-COMPUTED TICKER STRINGS — avoid re-parsing every f_checkSMT call
var string chartRoot = str.upper(syminfo.root)
var bool chartIsES = chartRoot == 'ES' or chartRoot == 'MES'
var bool chartIsNQ = chartRoot == 'NQ' or chartRoot == 'MNQ'
var string sym1Resolved = sym1AutoESNQ ? (chartIsES ? 'CME_MINI:NQ1!' : chartIsNQ ? 'CME_MINI:ES1!' : sym1Input) : sym1Input

var string sym1Short = f_ticker(sym1Resolved)
var string sym2Short = f_ticker(sym2Input)
var string sym3Short = f_ticker(sym3Input)

// ████████████████████████████████████████████████████████████████████████
// REFERENCE SYMBOL DATA (NON-REPAINT) — tuple returns: 3 calls instead of 6
// ████████████████████████████████████████████████████████████████████████
float ref1H = na, float ref1L = na
float ref2H = na, float ref2L = na
float ref3H = na, float ref3L = na

if sym1On
    [h1, l1] = request.security(sym1Resolved, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref1H := h1
    ref1L := l1

if sym2On
    [h2, l2] = request.security(sym2Input, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref2H := h2
    ref2L := l2

if sym3On
    [h3, l3] = request.security(sym3Input, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref3H := h3
    ref3L := l3

// ████████████████████████████████████████████████████████████████████████
// SWING CALCULATIONS (NO-LAG) — breakout on rolling highs/lows
// ████████████████████████████████████████████████████████████████████████
bool needR1 = range1On and (sym1On or sym2On or sym3On)
bool needR2 = range2On and (sym1On or sym2On or sym3On)
bool needR3 = range3On and (sym1On or sym2On or sym3On)
bool useCloseBreak = swingTriggerMode == 'CloseBreak'

// Range 1 — Micro: 2, 3, 5, 6, 8, 10
float cPH_2  = needR1 and useCloseBreak and close > ta.highest(high[1], 2)  ? high : na, float cPL_2  = needR1 and useCloseBreak and close < ta.lowest(low[1], 2)   ? low : na
float cPH_3  = needR1 and useCloseBreak and close > ta.highest(high[1], 3)  ? high : na, float cPL_3  = needR1 and useCloseBreak and close < ta.lowest(low[1], 3)   ? low : na
float cPH_5  = needR1 and useCloseBreak and close > ta.highest(high[1], 5)  ? high : na, float cPL_5  = needR1 and useCloseBreak and close < ta.lowest(low[1], 5)   ? low : na
float cPH_6  = needR1 and useCloseBreak and close > ta.highest(high[1], 6)  ? high : na, float cPL_6  = needR1 and useCloseBreak and close < ta.lowest(low[1], 6)   ? low : na
float cPH_8  = needR1 and useCloseBreak and close > ta.highest(high[1], 8)  ? high : na, float cPL_8  = needR1 and useCloseBreak and close < ta.lowest(low[1], 8)   ? low : na
float cPH_10 = needR1 and useCloseBreak and close > ta.highest(high[1], 10) ? high : na, float cPL_10 = needR1 and useCloseBreak and close < ta.lowest(low[1], 10)  ? low : na

// Range 2 — Intraday: 12, 14, 17, 20, 22, 25
float cPH_12 = needR2 and useCloseBreak and close > ta.highest(high[1], 12) ? high : na, float cPL_12 = needR2 and useCloseBreak and close < ta.lowest(low[1], 12)  ? low : na
float cPH_14 = needR2 and useCloseBreak and close > ta.highest(high[1], 14) ? high : na, float cPL_14 = needR2 and useCloseBreak and close < ta.lowest(low[1], 14)  ? low : na
float cPH_17 = needR2 and useCloseBreak and close > ta.highest(high[1], 17) ? high : na, float cPL_17 = needR2 and useCloseBreak and close < ta.lowest(low[1], 17)  ? low : na
float cPH_20 = needR2 and useCloseBreak and close > ta.highest(high[1], 20) ? high : na, float cPL_20 = needR2 and useCloseBreak and close < ta.lowest(low[1], 20)  ? low : na
float cPH_22 = needR2 and useCloseBreak and close > ta.highest(high[1], 22) ? high : na, float cPL_22 = needR2 and useCloseBreak and close < ta.lowest(low[1], 22)  ? low : na
float cPH_25 = needR2 and useCloseBreak and close > ta.highest(high[1], 25) ? high : na, float cPL_25 = needR2 and useCloseBreak and close < ta.lowest(low[1], 25)  ? low : na

// Range 3 — Session: 30, 35, 40, 45, 50, 60
float cPH_30 = needR3 and useCloseBreak and close > ta.highest(high[1], 30) ? high : na, float cPL_30 = needR3 and useCloseBreak and close < ta.lowest(low[1], 30)  ? low : na
float cPH_35 = needR3 and useCloseBreak and close > ta.highest(high[1], 35) ? high : na, float cPL_35 = needR3 and useCloseBreak and close < ta.lowest(low[1], 35)  ? low : na
float cPH_40 = needR3 and useCloseBreak and close > ta.highest(high[1], 40) ? high : na, float cPL_40 = needR3 and useCloseBreak and close < ta.lowest(low[1], 40)  ? low : na
float cPH_45 = needR3 and useCloseBreak and close > ta.highest(high[1], 45) ? high : na, float cPL_45 = needR3 and useCloseBreak and close < ta.lowest(low[1], 45)  ? low : na
float cPH_50 = needR3 and useCloseBreak and close > ta.highest(high[1], 50) ? high : na, float cPL_50 = needR3 and useCloseBreak and close < ta.lowest(low[1], 50)  ? low : na
float cPH_60 = needR3 and useCloseBreak and close > ta.highest(high[1], 60) ? high : na, float cPL_60 = needR3 and useCloseBreak and close < ta.lowest(low[1], 60)  ? low : na

// Ref1 swings
bool need1R1 = needR1 and sym1On, bool need1R2 = needR2 and sym1On, bool need1R3 = needR3 and sym1On
float r1PH_2  = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 2)  ? ref1H : na, float r1PL_2  = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 2)   ? ref1L : na
float r1PH_3  = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 3)  ? ref1H : na, float r1PL_3  = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 3)   ? ref1L : na
float r1PH_5  = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 5)  ? ref1H : na, float r1PL_5  = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 5)   ? ref1L : na
float r1PH_6  = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 6)  ? ref1H : na, float r1PL_6  = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 6)   ? ref1L : na
float r1PH_8  = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 8)  ? ref1H : na, float r1PL_8  = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 8)   ? ref1L : na
float r1PH_10 = need1R1 and useCloseBreak and ref1H > ta.highest(ref1H[1], 10) ? ref1H : na, float r1PL_10 = need1R1 and useCloseBreak and ref1L < ta.lowest(ref1L[1], 10)  ? ref1L : na
