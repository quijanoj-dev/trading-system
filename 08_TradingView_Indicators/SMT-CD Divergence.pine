// ████████████████████████████████████████████████████████████████████████
// RESOLVED STYLES — pre-computed once (var)
// ████████████████████████████████████████████████████████████████████████
var string bullStyleEnum = switch bullLineStyle
    'Solid'  => line.style_solid
    'Dashed' => line.style_dashed
    'Dotted' => line.style_dotted
    => line.style_solid

var string bearStyleEnum = switch bearLineStyle
    'Solid'  => line.style_solid
    'Dashed' => line.style_dashed
    'Dotted' => line.style_dotted
    => line.style_solid

// PRE-COMPUTED COLORS
var float invAlpha      = color.t(invalidColor)
var color fadedText     = color.new(color.white, invAlpha)

// CDDO constants and pre-computed values
var float priceTol        = priceToleranceTicks * syminfo.mintick
var float negExtremeLevel = -extremeLevel
var int   pairTolerance   = math.round(pivotLen * pivotToleranceMult)
var float blendWeightKVO  = 1.0 - blendWeightCDDO
var bool  needEma         = useTrendFilter or useSlopeAlign

var int GRADE_ELITE    = 8
var int GRADE_STRONG   = 5
var int GRADE_MODERATE = 3

var string TIER_REG_1 = ' ◆'
var string TIER_REG_2 = ' ◆◆'
var string TIER_REG_3 = ' ◆◆◆'
var string TIER_HID_1 = ' ◇'
var string TIER_HID_2 = ' ◇◇'
var string TIER_HID_3 = ' ◇◇◇'

f_higher_or_equal(float cur, float prev, float tol) =>
    cur >= prev - tol

f_lower_or_equal(float cur, float prev, float tol) =>
    cur <= prev + tol

// Realtime mode: mark prior closed bar as a pivot if it beats the left-side lookback.
f_rt_pivothigh(float src, int leftBars) =>
    bool enough = leftBars > 0 and not na(src[leftBars + 1])
    float leftMax = enough ? ta.highest(src[2], leftBars) : na
    enough and src[1] > leftMax ? src[1] : na

f_rt_pivotlow(float src, int leftBars) =>
    bool enough = leftBars > 0 and not na(src[leftBars + 1])
    float leftMin = enough ? ta.lowest(src[2], leftBars) : na
    enough and src[1] < leftMin ? src[1] : na

f_smt_pivothigh(float src, int leftBars, int rightBars) =>
    rightBars == 0 ? f_rt_pivothigh(src, leftBars) : ta.pivothigh(src, leftBars, rightBars)

f_smt_pivotlow(float src, int leftBars, int rightBars) =>
    rightBars == 0 ? f_rt_pivotlow(src, leftBars) : ta.pivotlow(src, leftBars, rightBars)

f_smt_pivot_offset(int rightBars) =>
    rightBars == 0 ? 1 : rightBars

f_pivothigh(float src, int len) =>
    useRealtimePivots ? f_rt_pivothigh(src, len) : ta.pivothigh(src, len, len)

f_pivotlow(float src, int len) =>
    useRealtimePivots ? f_rt_pivotlow(src, len) : ta.pivotlow(src, len, len)

f_pivot_offset(int len) =>
    useRealtimePivots ? 1 : len

f_push_pair(array<int> _bars, array<float> _priceRaw, array<float> _oscRaw, int _bar, float _p, float _o, int _maxSize) =>
    int sz = array.size(_bars)
    bool added = sz == 0 or array.get(_bars, sz - 1) != _bar
    if added
        array.push(_bars, _bar)
        array.push(_priceRaw, _p)
        array.push(_oscRaw, _o)
        if array.size(_bars) > _maxSize
            array.shift(_bars)
            array.shift(_priceRaw)
            array.shift(_oscRaw)
    added

f_bullish_candle(int offset) =>
    float o = open[offset], float c = close[offset]
    float h = high[offset], float l = low[offset]
    float po = open[offset + 1], float pc = close[offset + 1]
    float body = math.abs(c - o)
    float rng = math.max(h - l, syminfo.mintick)
    float lowerWick = math.min(o, c) - l
    float upperWick = h - math.max(o, c)
    bool engulfing = c > o and pc < po and c > po and o < pc
    bool hammer = lowerWick >= body * 2.0 and upperWick < body * 0.5 and body > 0
    bool pinBar = lowerWick / rng >= 0.66
    engulfing or hammer or pinBar

f_bearish_candle(int offset) =>
    float o = open[offset], float c = close[offset]
    float h = high[offset], float l = low[offset]
    float po = open[offset + 1], float pc = close[offset + 1]
    float body = math.abs(c - o)
    float rng = math.max(h - l, syminfo.mintick)
    float lowerWick = math.min(o, c) - l
    float upperWick = h - math.max(o, c)
    bool engulfing = c < o and pc > po and c < po and o > pc
    bool shootingStar = upperWick >= body * 2.0 and lowerWick < body * 0.5 and body > 0
    bool pinBar = upperWick / rng >= 0.66
    engulfing or shootingStar or pinBar

f_tier_label_reg(int grade) =>
    grade >= GRADE_ELITE ? TIER_REG_3 : grade >= GRADE_STRONG ? TIER_REG_2 : TIER_REG_1

f_tier_label_hid(int grade) =>
    grade >= GRADE_ELITE ? TIER_HID_3 : grade >= GRADE_STRONG ? TIER_HID_2 : TIER_HID_1

// PRE-COMPUTED TICKER STRINGS — avoid re-parsing every f_checkSMT call
var string chartRoot = str.upper(syminfo.root)
var bool chartIsES = chartRoot == 'ES' or chartRoot == 'MES'
var bool chartIsNQ = chartRoot == 'NQ' or chartRoot == 'MNQ'
var string sym1Resolved = sym1AutoESNQ ? (chartIsES ? 'CME_MINI:NQ1!' : chartIsNQ ? 'CME_MINI:ES1!' : sym1Input) : sym1Input

var string sym1Short = f_ticker(sym1Resolved)
var string sym2Short = f_ticker(sym2Input)
var string sym3Short = f_ticker(sym3Input)

// ████████████████████████████████████████████████████████████████████████
// REFERENCE SYMBOL DATA (NON-REPAINT) — tuple returns: 3 calls instead of 6
// ████████████████████████████████████████████████████████████████████████
float ref1H = na, float ref1L = na
float ref2H = na, float ref2L = na
float ref3H = na, float ref3L = na
if sym1On
    [h1, l1] = request.security(sym1Resolved, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref1H := h1
    ref1L := l1
if sym2On
    [h2, l2] = request.security(sym2Input, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref2H := h2
    ref2L := l2
if sym3On
    [h3, l3] = request.security(sym3Input, timeframe.period, [high, low], barmerge.gaps_off, barmerge.lookahead_off)
    ref3H := h3
    ref3L := l3

// ████████████████████████████████████████████████████████████████████████
// PIVOT CALCULATIONS — CONDITIONAL by range toggle
// Only compute pivots for ranges that are actually enabled
// ████████████████████████████████████████████████████████████████████████
// Determine which ranges are actually needed (any symbol using them)
bool needR1 = range1On and (sym1On or sym2On or sym3On)
bool needR2 = range2On and (sym1On or sym2On or sym3On)
bool needR3 = range3On and (sym1On or sym2On or sym3On)

// Range 1 — Micro: 2, 3, 5, 6, 8, 10
float cPH_2  = needR1 ? f_smt_pivothigh(high, 2, smtRightBarsR1)   : na,   float cPL_2  = needR1 ? f_smt_pivotlow(low, 2, smtRightBarsR1)   : na
float cPH_3  = needR1 ? f_smt_pivothigh(high, 3, smtRightBarsR1)   : na,   float cPL_3  = needR1 ? f_smt_pivotlow(low, 3, smtRightBarsR1)   : na
float cPH_5  = needR1 ? f_smt_pivothigh(high, 5, smtRightBarsR1)   : na,   float cPL_5  = needR1 ? f_smt_pivotlow(low, 5, smtRightBarsR1)   : na
float cPH_6  = needR1 ? f_smt_pivothigh(high, 6, smtRightBarsR1)   : na,   float cPL_6  = needR1 ? f_smt_pivotlow(low, 6, smtRightBarsR1)   : na
float cPH_8  = needR1 ? f_smt_pivothigh(high, 8, smtRightBarsR1)   : na,   float cPL_8  = needR1 ? f_smt_pivotlow(low, 8, smtRightBarsR1)   : na
float cPH_10 = needR1 ? f_smt_pivothigh(high, 10, smtRightBarsR1)  : na,   float cPL_10 = needR1 ? f_smt_pivotlow(low, 10, smtRightBarsR1)  : na
// Range 2 — Intraday: 12, 14, 17, 20, 22, 25
float cPH_12 = needR2 ? f_smt_pivothigh(high, 12, smtRightBarsR2) : na,   float cPL_12 = needR2 ? f_smt_pivotlow(low, 12, smtRightBarsR2) : na
float cPH_14 = needR2 ? f_smt_pivothigh(high, 14, smtRightBarsR2) : na,   float cPL_14 = needR2 ? f_smt_pivotlow(low, 14, smtRightBarsR2) : na
float cPH_17 = needR2 ? f_smt_pivothigh(high, 17, smtRightBarsR2) : na,   float cPL_17 = needR2 ? f_smt_pivotlow(low, 17, smtRightBarsR2) : na
float cPH_20 = needR2 ? f_smt_pivothigh(high, 20, smtRightBarsR2) : na,   float cPL_20 = needR2 ? f_smt_pivotlow(low, 20, smtRightBarsR2) : na
float cPH_22 = needR2 ? f_smt_pivothigh(high, 22, smtRightBarsR2) : na,   float cPL_22 = needR2 ? f_smt_pivotlow(low, 22, smtRightBarsR2) : na
float cPH_25 = needR2 ? f_smt_pivothigh(high, 25, smtRightBarsR2) : na,   float cPL_25 = needR2 ? f_smt_pivotlow(low, 25, smtRightBarsR2) : na
// Range 3 — Session: 30, 35, 40, 45, 50, 60
float cPH_30 = needR3 ? f_smt_pivothigh(high, 30, smtRightBarsR3) : na,   float cPL_30 = needR3 ? f_smt_pivotlow(low, 30, smtRightBarsR3) : na
float cPH_35 = needR3 ? f_smt_pivothigh(high, 35, smtRightBarsR3) : na,   float cPL_35 = needR3 ? f_smt_pivotlow(low, 35, smtRightBarsR3) : na
float cPH_40 = needR3 ? f_smt_pivothigh(high, 40, smtRightBarsR3) : na,   float cPL_40 = needR3 ? f_smt_pivotlow(low, 40, smtRightBarsR3) : na
float cPH_45 = needR3 ? f_smt_pivothigh(high, 45, smtRightBarsR3) : na,   float cPL_45 = needR3 ? f_smt_pivotlow(low, 45, smtRightBarsR3) : na
float cPH_50 = needR3 ? f_smt_pivothigh(high, 50, smtRightBarsR3) : na,   float cPL_50 = needR3 ? f_smt_pivotlow(low, 50, smtRightBarsR3) : na
float cPH_60 = needR3 ? f_smt_pivothigh(high, 60, smtRightBarsR3) : na,   float cPL_60 = needR3 ? f_smt_pivotlow(low, 60, smtRightBarsR3) : na

// Ref1 pivots — conditional on sym1On + range toggles
bool need1R1 = needR1 and sym1On,  bool need1R2 = needR2 and sym1On,  bool need1R3 = needR3 and sym1On
float r1PH_2  = need1R1 ? f_smt_pivothigh(ref1H, 2, smtRightBarsR1)   : na,   float r1PL_2  = need1R1 ? f_smt_pivotlow(ref1L, 2, smtRightBarsR1)   : na
