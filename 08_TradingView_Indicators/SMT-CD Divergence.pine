indicator("SMT-CD-GPT Div Optimized", shorttitle="SMT-CD Divergence", overlay=true, max_labels_count=500, max_lines_count=500)

// ████████████████████████████████████████████████████████████████████████
// HELPERS
// ███████████████████████████████████████████████████∫█████████████████████
f_fmt(float x) =>
    str.tostring(x, format.mintick)

f_ticker(string sym) =>
    int p = str.pos(sym, ':')
    p >= 0 ? str.substring(sym, p + 1) : sym

