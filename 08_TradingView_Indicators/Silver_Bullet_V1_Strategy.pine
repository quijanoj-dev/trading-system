//@version=6
// Silver Bullet V1 — Backtestable approximation of the 4-signal confluence system.
// Rules: 10:00-11:00 ET | stop hunt | confirmed SMT | FVG | CHoCH minimum
// NOTE: simplified proxies — not identical to indicator output.
// LIMITATION: TV Strategy Tester on 1m ES1! loads ~16 trading days (~20k bars).
//   At ~1 qualifying setup per week, expect 2-4 trades in 16 days — may be 0.
//   For 3-month runs use the Python backtester (execution/market_data/).
// FIX (v2): each signal tracked via state variable (active for i_expiry bars).
//   CHoCH is the entry trigger; hunt+FVG+SMT must each have fired within expiry window.
//   Previous version incorrectly required all 4 signals on the same single bar.
strategy(
    title              = "Silver Bullet V1 — 10:00–11:00 ET",
    shorttitle         = "SBV1",
    overlay            = true,
    initial_capital    = 25000,
    default_qty_type   = strategy.fixed,
    default_qty_value  = 1,
    commission_type    = strategy.commission.cash_per_contract,
    commission_value   = 2.50,
    slippage           = 1,
    calc_on_every_tick = false
)

grpTime  = "Session"
grpSetup = "Setup Parameters"
grpRisk  = "Risk"

i_session = input.session("1000-1100", "Silver Bullet Window (ET)", group=grpTime)
i_tz      = input.string("America/New_York", "Timezone", group=grpTime)
i_sym2    = input.symbol("NQ1!", "SMT Symbol (correlated pair)", group=grpSetup,
             tooltip="For ES1! use NQ1!. For NQ1! use ES1!.")
i_swing   = input.int(5,   "Swing Pivot Length",  minval=2, maxval=20, group=grpSetup)
i_shbars  = input.int(20,  "Stop Hunt Lookback",  minval=5, maxval=60, group=grpSetup)
i_fvgmin  = input.float(1.0, "Min FVG (points)", minval=0.1, group=grpSetup)
i_expiry  = input.int(6,   "Setup Expiry (bars)", minval=2, maxval=20, group=grpSetup,
             tooltip="Bars after each signal fires within which it stays active. CHoCH must arrive within this window.")
i_r       = input.float(2.0, "R Multiple Target", minval=0.5, step=0.5, group=grpRisk)

// ─── SESSION ──────────────────────────────────────────────────────────────────
inSession = not na(time(timeframe.period, i_session, i_tz))

// ─── SMT ──────────────────────────────────────────────────────────────────────
sym2Low  = request.security(i_sym2, timeframe.period, low,  barmerge.gaps_off, barmerge.lookahead_off)
sym2High = request.security(i_sym2, timeframe.period, high, barmerge.gaps_off, barmerge.lookahead_off)

// ─── SWINGS ───────────────────────────────────────────────────────────────────
ph = ta.pivothigh(high, i_swing, i_swing)
pl = ta.pivotlow(low,   i_swing, i_swing)

var float lastPH = na
var float lastPL = na
if not na(ph)
    lastPH := ph
if not na(pl)
    lastPL := pl

// ─── RAW SIGNALS ──────────────────────────────────────────────────────────────
recentLow   = ta.lowest(low[1],  i_shbars)
recentHigh  = ta.highest(high[1], i_shbars)
bullHuntRaw = low < recentLow  and close > recentLow
bearHuntRaw = high > recentHigh and close < recentHigh

bullFVGraw = low > high[2] and (low - high[2]) >= i_fvgmin
bearFVGraw = high < low[2] and (low[2] - high) >= i_fvgmin

bullSMTraw = low  < low[1]  and sym2Low  > sym2Low[1]
bearSMTraw = high > high[1] and sym2High < sym2High[1]

// CHoCH is the entry trigger — requires close to cross last pivot
bullCHoCH = not na(lastPH) and close > lastPH and close[1] <= lastPH
bearCHoCH = not na(lastPL) and close < lastPL and close[1] >= lastPL

// ─── STATE TRACKING (each signal stays active for i_expiry bars) ──────────────
var bool bullHuntOn  = false
var bool bearHuntOn  = false
var bool bullFVGon   = false
var bool bearFVGon   = false
var bool bullSMTon   = false
var bool bearSMTon   = false
var int  bullHuntBar = na
var int  bearHuntBar = na
var int  bullFVGbar  = na
var int  bearFVGbar  = na
var int  bullSMTbar  = na
var int  bearSMTbar  = na

if bullHuntRaw and inSession
    bullHuntOn  := true
    bullHuntBar := bar_index
if bearHuntRaw and inSession
    bearHuntOn  := true
    bearHuntBar := bar_index
if bullFVGraw and inSession
    bullFVGon  := true
    bullFVGbar := bar_index
if bearFVGraw and inSession
    bearFVGon  := true
    bearFVGbar := bar_index
if bullSMTraw and inSession
    bullSMTon  := true
    bullSMTbar := bar_index
if bearSMTraw and inSession
    bearSMTon  := true
    bearSMTbar := bar_index

if bullHuntOn and not na(bullHuntBar) and bar_index - bullHuntBar > i_expiry
    bullHuntOn := false
if bearHuntOn and not na(bearHuntBar) and bar_index - bearHuntBar > i_expiry
    bearHuntOn := false
if bullFVGon and not na(bullFVGbar) and bar_index - bullFVGbar > i_expiry
    bullFVGon := false
if bearFVGon and not na(bearFVGbar) and bar_index - bearFVGbar > i_expiry
    bearFVGon := false
if bullSMTon and not na(bullSMTbar) and bar_index - bullSMTbar > i_expiry
    bullSMTon := false
if bearSMTon and not na(bearSMTbar) and bar_index - bearSMTbar > i_expiry
    bearSMTon := false

// ─── ENTRY: CHoCH triggers — all 3 prior signals must be active ───────────────
goLong  = bullCHoCH and bullHuntOn and bullFVGon and bullSMTon and inSession and strategy.position_size == 0
goShort = bearCHoCH and bearHuntOn and bearFVGon and bearSMTon and inSession and strategy.position_size == 0

// ─── STOP / TARGET ────────────────────────────────────────────────────────────
longStop    = low[1]
shortStop   = high[1]
longTarget  = close + (close - longStop)  * i_r
shortTarget = close - (shortStop - close) * i_r

// ─── EXECUTE ──────────────────────────────────────────────────────────────────
if goLong
    strategy.entry("Long", strategy.long)
    strategy.exit("Long XIT", "Long", stop=longStop, limit=longTarget)
    bullHuntOn := false
    bullFVGon  := false
    bullSMTon  := false

if goShort
    strategy.entry("Short", strategy.short)
    strategy.exit("Short XIT", "Short", stop=shortStop, limit=shortTarget)
    bearHuntOn := false
    bearFVGon  := false
    bearSMTon  := false

if not inSession and strategy.position_size != 0
    strategy.close_all(comment="session end")

// ─── VISUALS ──────────────────────────────────────────────────────────────────
bgcolor(inSession ? color.new(color.blue, 93) : na, title="Silver Bullet Window")
plotshape(bullHuntRaw and inSession, "Bull Hunt",   shape.triangleup,   location.belowbar, color.new(color.green,0), size=size.tiny)
plotshape(bearHuntRaw and inSession, "Bear Hunt",   shape.triangledown, location.abovebar, color.new(color.red,  0), size=size.tiny)
plotshape(goLong,                    "Long Entry",  shape.labelup,      location.belowbar, color.lime, size=size.small, text="L")
plotshape(goShort,                   "Short Entry", shape.labeldown,    location.abovebar, color.red,  size=size.small, text="S")
plotshape(bullSMTraw and inSession,  "Bull SMT",    shape.circle,       location.belowbar, color.new(color.teal,  40), size=size.tiny)
plotshape(bearSMTraw and inSession,  "Bear SMT",    shape.circle,       location.abovebar, color.new(color.orange,40), size=size.tiny)
plotshape(bullCHoCH and inSession,   "Bull CHoCH",  shape.cross,        location.belowbar, color.new(color.aqua,  40), size=size.tiny)
plotshape(bearCHoCH and inSession,   "Bear CHoCH",  shape.cross,        location.abovebar, color.new(color.purple,40), size=size.tiny)
