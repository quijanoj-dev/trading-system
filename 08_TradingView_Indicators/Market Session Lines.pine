//@version=6
indicator("Market Session Lines", overlay = true, max_lines_count = 500, max_labels_count = 500)

// =============================================================================
// INPUTS
// =============================================================================
string groupTZ = "Timezone"
string i_timezone = input.string(
     "America/New_York",
     "Timezone",
     options = ["America/New_York", "America/Bogota", "America/Chicago", "America/Los_Angeles", "Europe/London", "Asia/Tokyo", "Etc/UTC"],
     group = groupTZ)

string groupHist = "Historical Control"
int i_keepHistoricalDays = input.int(5, "Keep last N days (Historical)", minval = 1, maxval = 30, group = groupHist)

string groupMO = "Market Open (09:30)"
bool i_showMarketOpen = input.bool(true, "Show", group = groupMO, inline = "mo_time")
int i_marketOpenHour = input.int(9, "Hour", minval = 0, maxval = 23, group = groupMO, inline = "mo_time")
int i_marketOpenMin = input.int(30, "Minute", minval = 0, maxval = 59, group = groupMO, inline = "mo_time")
color i_marketOpenColor = input.color(color.aqua, "Color", group = groupMO, inline = "mo_style")
string i_marketOpenStyle = input.string("Dashed", "Style", options = ["Solid", "Dashed", "Dotted"], group = groupMO, inline = "mo_style")
int i_marketOpenWidth = input.int(1, "Width", minval = 1, maxval = 4, group = groupMO, inline = "mo_style")

string groupNR = "Noon Relax (12:00)"
bool i_showNoonRelax = input.bool(true, "Show", group = groupNR, inline = "nr_time")
int i_noonRelaxHour = input.int(12, "Hour", minval = 0, maxval = 23, group = groupNR, inline = "nr_time")
int i_noonRelaxMin = input.int(0, "Minute", minval = 0, maxval = 59, group = groupNR, inline = "nr_time")
color i_noonRelaxColor = input.color(color.yellow, "Color", group = groupNR, inline = "nr_style")
string i_noonRelaxStyle = input.string("Dashed", "Style", options = ["Solid", "Dashed", "Dotted"], group = groupNR, inline = "nr_style")
int i_noonRelaxWidth = input.int(1, "Width", minval = 1, maxval = 4, group = groupNR, inline = "nr_style")

string groupPH = "Power Hour (15:00)"
bool i_showPowerHour = input.bool(true, "Show", group = groupPH, inline = "ph_time")
int i_powerHourHour = input.int(15, "Hour", minval = 0, maxval = 23, group = groupPH, inline = "ph_time")
int i_powerHourMin = input.int(0, "Minute", minval = 0, maxval = 59, group = groupPH, inline = "ph_time")
color i_powerHourColor = input.color(color.white, "Color", group = groupPH, inline = "ph_style")
string i_powerHourStyle = input.string("Dashed", "Style", options = ["Solid", "Dashed", "Dotted"], group = groupPH, inline = "ph_style")
int i_powerHourWidth = input.int(1, "Width", minval = 1, maxval = 4, group = groupPH, inline = "ph_style")

string groupMC = "Market Close (16:00)"
bool i_showMarketClose = input.bool(true, "Show", group = groupMC, inline = "mc_time")
int i_marketCloseHour = input.int(16, "Hour", minval = 0, maxval = 23, group = groupMC, inline = "mc_time")
int i_marketCloseMin = input.int(0, "Minute", minval = 0, maxval = 59, group = groupMC, inline = "mc_time")
color i_marketCloseColor = input.color(color.fuchsia, "Color", group = groupMC, inline = "mc_style")
string i_marketCloseStyle = input.string("Dashed", "Style", options = ["Solid", "Dashed", "Dotted"], group = groupMC, inline = "mc_style")
int i_marketCloseWidth = input.int(1, "Width", minval = 1, maxval = 4, group = groupMC, inline = "mc_style")

string groupFP = "Future Projection"
int i_futureDays = input.int(1, "Days to Project (D+1..D+N)", minval = 0, maxval = 10, group = groupFP)
int i_maxFutureMinutesVisible = input.int(1440, "Max future minutes visible", minval = 30, maxval = 1440, group = groupFP)

// =============================================================================
// HELPERS
// =============================================================================
lineStyleFromText(string styleText) =>
    switch styleText
        "Dashed" => line.style_dashed
        "Dotted" => line.style_dotted
        => line.style_solid

isWeekendTS(int ts) =>
    int dow = dayofweek(ts, i_timezone)
    dow == dayofweek.saturday or dow == dayofweek.sunday

sessionTS(int y, int m, int d, int h, int min) =>
    int ts0 = timestamp(i_timezone, y, m, d, h, min, 0)
    int localTotalMin = hour(ts0, i_timezone) * 60 + minute(ts0, i_timezone)
    int targetTotalMin = h * 60 + min
    ts0 + (targetTotalMin - localTotalMin) * 60000

// =============================================================================
// DERIVED SETTINGS
// =============================================================================
lsMO = lineStyleFromText(i_marketOpenStyle)
lsNR = lineStyleFromText(i_noonRelaxStyle)
lsPH = lineStyleFromText(i_powerHourStyle)
lsMC = lineStyleFromText(i_marketCloseStyle)

int futureLimitOffsetMs = i_maxFutureMinutesVisible * 60000
int keepLineCount = i_keepHistoricalDays * 4

var array<string> dPlusSuffix = array.new_string()
if barstate.isfirst
    for i = 1 to 10
        dPlusSuffix.push(" (D+" + str.tostring(i) + ")")

// =============================================================================
// TIME CACHE
// =============================================================================
bool isIntradayTF = timeframe.isintraday
int tNow = time

int curY = year(tNow, i_timezone)
int curMo = month(tNow, i_timezone)
int curD = dayofmonth(tNow, i_timezone)
int dayKey = curY * 10000 + curMo * 100 + curD

int tsMO = sessionTS(curY, curMo, curD, i_marketOpenHour, i_marketOpenMin)
int tsNR = sessionTS(curY, curMo, curD, i_noonRelaxHour, i_noonRelaxMin)
int tsPH = sessionTS(curY, curMo, curD, i_powerHourHour, i_powerHourMin)
int tsMC = sessionTS(curY, curMo, curD, i_marketCloseHour, i_marketCloseMin)

// =============================================================================
// LABEL ANCHORS
// =============================================================================
int topLookback = 250
float topPad = isIntradayTF ? math.max(ta.atr(14) * 2.0, syminfo.mintick * 200.0) : na
float topY = isIntradayTF ? ta.highest(high, topLookback) + topPad : na

float span = isIntradayTF ? math.max(ta.tr(true), syminfo.mintick * 50.0) : na
float labelPriceHigh = isIntradayTF ? high + span : na
float labelPriceLow = isIntradayTF ? low - span : na

// =============================================================================
// STATE CONTAINERS
// =============================================================================
var array<line> histLines = array.new_line()
var array<label> histLabels = array.new_label()
var array<int> histDays = array.new_int()

var array<line> futureLines = array.new_line()
var array<label> futureLabels = array.new_label()
var float lastRoofY = na

var array<int> futureDayKeys = array.new_int()
var int cachedDayKey = na
var int cachedN = na

var array<int> tmpTS = array.new_int()
var array<string> tmpText = array.new_string()
var array<color> tmpCol = array.new_color()
var array<int> tmpWid = array.new_int()
var array<string> tmpStyleText = array.new_string()

// =============================================================================
// HELPERS: STATE MANAGEMENT
// =============================================================================
trimHistorical(array<line> lineArr, array<label> labelArr, array<int> dayArr, int keepDays) =>
    while dayArr.size() > keepDays
        dayArr.shift()
        if lineArr.size() > 0
            line.delete(lineArr.shift())
        if labelArr.size() > 0
            label.delete(labelArr.shift())

ensureFutureSize(array<line> lineArr, array<label> labelArr, int needed) =>
    while lineArr.size() < needed
        lineArr.push(line.new(tNow, labelPriceHigh, tNow, labelPriceLow, xloc.bar_time, extend.both, color.gray, line.style_solid, 1))
    while labelArr.size() < needed
        label lb = label.new(tNow, topY, "", xloc.bar_time, yloc.price, color.gray, label.style_label_down, color.black, size.small)
        label.set_textcolor(lb, color.black)
        label.set_style(lb, label.style_label_down)
        label.set_size(lb, size.small)
        labelArr.push(lb)
    while lineArr.size() > needed
        line.delete(lineArr.pop())
    while labelArr.size() > needed
        label.delete(labelArr.pop())

rebuildFutureDayDates() =>
    futureDayKeys.clear()
    if i_futureDays > 0
        int baseNoon = sessionTS(curY, curMo, curD, 12, 0)
        int scanned = 0
        int found = 0
        int maxScan = i_futureDays * 3
        while found < i_futureDays and scanned < maxScan
            scanned += 1
            int candNoon = baseNoon + scanned * 86400000
            if not isWeekendTS(candNoon)
                found += 1
                int y = year(candNoon, i_timezone)
                int m = month(candNoon, i_timezone)
                int d = dayofmonth(candNoon, i_timezone)
                futureDayKeys.push(y * 10000 + m * 100 + d)

tmpClear() =>
    tmpTS.clear()
    tmpText.clear()
    tmpCol.clear()
    tmpWid.clear()
    tmpStyleText.clear()

tmpPush(int ts, string txt, color col, int wid, string lineStyleText) =>
    tmpTS.push(ts)
    tmpText.push(txt)
    tmpCol.push(col)
    tmpWid.push(wid)
    tmpStyleText.push(lineStyleText)

alignLabelRoof(array<label> labelArr, float roofY) =>
    int sz = labelArr.size()
    if sz > 0
        for i = 0 to sz - 1
            label lb = labelArr.get(i)
            label.set_y(lb, roofY)

drawHistoricalTS(bool show, int targetTS, color col, lineStyle, int wid, string labelText) =>
    if show
        bool didCrossTarget = tNow <= targetTS and time_close > targetTS
        if didCrossTarget
            line ln = line.new(targetTS, labelPriceHigh, targetTS, labelPriceLow, xloc.bar_time, extend.both, col, lineStyle, wid)
            label lb = label.new(targetTS, topY, labelText, xloc.bar_time, yloc.price, col, label.style_label_down, color.black, size.small)
            histLines.push(ln)
            histLabels.push(lb)
            histDays.push(dayKey)
            trimHistorical(histLines, histLabels, histDays, keepLineCount)

collectFuture(bool show, int todayTS, int targetHour, int targetMin, color col, string lineStyleText, int wid, string baseText, int futureLimitTS) =>
    if show
        if todayTS >= tNow
            tmpPush(todayTS, baseText, col, wid, lineStyleText)

        int sz = futureDayKeys.size()
        if sz > 0
            for j = 0 to sz - 1
                int dayKeyF = futureDayKeys.get(j)
                int y = int(dayKeyF / 10000)
                int m = int((dayKeyF % 10000) / 100)
                int d = dayKeyF % 100
                int fTS = sessionTS(y, m, d, targetHour, targetMin)
                if fTS > futureLimitTS
                    break
                tmpPush(fTS, baseText + dPlusSuffix.get(j), col, wid, lineStyleText)

// =============================================================================
// EXECUTION: FUTURE PROJECTIONS
// =============================================================================
if barstate.islast
    if cachedDayKey != dayKey or cachedN != i_futureDays
        cachedDayKey := dayKey
        cachedN := i_futureDays
        rebuildFutureDayDates()

    tmpClear()

    if isIntradayTF
        int futureLimitTS = tNow + futureLimitOffsetMs
        collectFuture(i_showMarketOpen, tsMO, i_marketOpenHour, i_marketOpenMin, i_marketOpenColor, i_marketOpenStyle, i_marketOpenWidth, "MARKET OPEN", futureLimitTS)
        collectFuture(i_showNoonRelax, tsNR, i_noonRelaxHour, i_noonRelaxMin, i_noonRelaxColor, i_noonRelaxStyle, i_noonRelaxWidth, "NOON RELAX", futureLimitTS)
        collectFuture(i_showPowerHour, tsPH, i_powerHourHour, i_powerHourMin, i_powerHourColor, i_powerHourStyle, i_powerHourWidth, "POWER HOUR", futureLimitTS)
        collectFuture(i_showMarketClose, tsMC, i_marketCloseHour, i_marketCloseMin, i_marketCloseColor, i_marketCloseStyle, i_marketCloseWidth, "MARKET CLOSE", futureLimitTS)

    int needed = tmpTS.size()
    ensureFutureSize(futureLines, futureLabels, needed)

    if needed > 0
        for idx = 0 to needed - 1
            int ts = tmpTS.get(idx)
            string txt = tmpText.get(idx)
            color col = tmpCol.get(idx)
            int wid = tmpWid.get(idx)
            string styleText = tmpStyleText.get(idx)

            line ln = futureLines.get(idx)
            line.set_xy1(ln, ts, labelPriceHigh)
            line.set_xy2(ln, ts, labelPriceLow)
            line.set_color(ln, col)
            line.set_style(ln, lineStyleFromText(styleText))
            line.set_width(ln, wid)

            label lb = futureLabels.get(idx)
            label.set_x(lb, ts)
            label.set_y(lb, topY)
            label.set_text(lb, txt)
            label.set_color(lb, col)

    if isIntradayTF and (na(lastRoofY) or topY != lastRoofY)
        alignLabelRoof(histLabels, topY)
        lastRoofY := topY

// =============================================================================
// EXECUTION: HISTORICAL LINES
// =============================================================================
if isIntradayTF and barstate.isconfirmed
    drawHistoricalTS(i_showMarketOpen, tsMO, i_marketOpenColor, lsMO, i_marketOpenWidth, "MARKET OPEN")
    drawHistoricalTS(i_showNoonRelax, tsNR, i_noonRelaxColor, lsNR, i_noonRelaxWidth, "NOON RELAX")
    drawHistoricalTS(i_showPowerHour, tsPH, i_powerHourColor, lsPH, i_powerHourWidth, "POWER HOUR")
    drawHistoricalTS(i_showMarketClose, tsMC, i_marketCloseColor, lsMC, i_marketCloseWidth, "MARKET CLOSE")
