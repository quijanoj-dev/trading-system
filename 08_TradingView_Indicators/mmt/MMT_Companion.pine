//@version=6
// MMT Companion — Money Market Theory framework indicator
// Shows: session ranges (Asia/London/NY), FVGs, order blocks, liquidity pools
// Designed for ES/NQ 1-5min charts. Works best with RTH sessions.
indicator("MMT Companion", overlay=true, max_boxes_count=200, max_lines_count=200, max_labels_count=200)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
var g_sess = "Session Settings"
show_asia    = input.bool(true,  "Show Asia Range",   group=g_sess)
show_london  = input.bool(true,  "Show London Range", group=g_sess)
show_ny      = input.bool(true,  "Show NY Kill Zone", group=g_sess)

var g_fvg = "Fair Value Gap"
show_fvg     = input.bool(true,  "Show FVGs",   group=g_fvg)
fvg_fill_col = input.color(color.new(color.blue, 80), "FVG Color", group=g_fvg)
fvg_min_size = input.float(0.0,  "Min FVG Size (pts)", group=g_fvg, minval=0)

var g_ob = "Order Blocks"
show_ob      = input.bool(true,  "Show Order Blocks", group=g_ob)
ob_bull_col  = input.color(color.new(color.green, 80), "Bullish OB", group=g_ob)
ob_bear_col  = input.color(color.new(color.red,   80), "Bearish OB", group=g_ob)

var g_liq = "Liquidity"
show_ssl     = input.bool(true,  "Show SSL (equal lows)",  group=g_liq)
show_bsl     = input.bool(true,  "Show BSL (equal highs)", group=g_liq)
eq_tolerance = input.float(0.05, "Equal H/L tolerance %",  group=g_liq, minval=0.01, maxval=1.0)

// ─── SESSION TIMES (ET) ───────────────────────────────────────────────────────
// All times in exchange timezone (US/Eastern for CME futures)
asia_start   = "1800-2000"    // 6PM-8PM prior day
london_start = "0300-0500"    // 3AM-5AM
ny_start     = "0930-1100"    // 9:30AM-11AM

in_asia   = not na(time("D", asia_start,   "America/New_York"))
in_london = not na(time("D", london_start, "America/New_York"))
in_ny     = not na(time("D", ny_start,     "America/New_York"))

// ─── SESSION RANGE TRACKING ───────────────────────────────────────────────────
var float asia_high = na, var float asia_low = na
var float london_high = na, var float london_low = na
var float ny_high = na, var float ny_low = na

var bool asia_open = false
var bool london_open = false
var bool ny_open = false

if in_asia and not asia_open
    asia_high := high
    asia_low  := low
    asia_open := true
else if in_asia
    asia_high := math.max(asia_high, high)
    asia_low  := math.min(asia_low, low)
else if asia_open
    asia_open := false

if in_london and not london_open
    london_high := high
    london_low  := low
    london_open := true
else if in_london
    london_high := math.max(london_high, high)
    london_low  := math.min(london_low, low)
else if london_open
    london_open := false

if in_ny and not ny_open
    ny_high := high
    ny_low  := low
    ny_open := true
else if in_ny
    ny_high := math.max(ny_high, high)
    ny_low  := math.min(ny_low, low)
else if ny_open
    ny_open := false

// Draw session range lines
if show_asia and not asia_open and not na(asia_high)
    line.new(bar_index - 1, asia_high, bar_index, asia_high, color=color.purple, width=1, style=line.style_dotted)
    line.new(bar_index - 1, asia_low,  bar_index, asia_low,  color=color.purple, width=1, style=line.style_dotted)

if show_london and not london_open and not na(london_high)
    line.new(bar_index - 1, london_high, bar_index, london_high, color=color.orange, width=1, style=line.style_dotted)
    line.new(bar_index - 1, london_low,  bar_index, london_low,  color=color.orange, width=1, style=line.style_dotted)

// Background shading for active sessions
bgcolor(show_asia   and in_asia   ? color.new(color.purple, 95) : na, title="Asia bg")
bgcolor(show_london and in_london ? color.new(color.orange, 95) : na, title="London bg")
bgcolor(show_ny     and in_ny     ? color.new(color.yellow, 92) : na, title="NY bg")

// ─── FAIR VALUE GAPS (FVG) ────────────────────────────────────────────────────
// Bullish FVG: high[2] < low[0] (gap between 3 candles)
// Bearish FVG: low[2] > high[0]
bull_fvg = high[2] < low[0] and (low[0] - high[2]) >= fvg_min_size
bear_fvg = low[2] > high[0] and (low[2] - high[0]) >= fvg_min_size

if show_fvg and bull_fvg
    box.new(bar_index - 2, low[0], bar_index + 20, high[2],
            border_color=color.new(color.blue, 70),
            bgcolor=fvg_fill_col,
            border_width=1)
    label.new(bar_index - 1, (low[0] + high[2]) / 2, "FVG↑",
              style=label.style_none, color=color.blue, size=size.tiny)

if show_fvg and bear_fvg
    box.new(bar_index - 2, high[0], bar_index + 20, low[2],
            border_color=color.new(color.red, 70),
            bgcolor=color.new(color.red, 85),
            border_width=1)
    label.new(bar_index - 1, (high[0] + low[2]) / 2, "FVG↓",
              style=label.style_none, color=color.red, size=size.tiny)

// ─── ORDER BLOCKS ─────────────────────────────────────────────────────────────
// Bullish OB: last bearish candle before a bullish impulse (3 consecutive up)
// Bearish OB: last bullish candle before a bearish impulse
bull_impulse = close[0] > close[1] and close[1] > close[2] and close[2] > close[3]
bear_impulse = close[0] < close[1] and close[1] < close[2] and close[2] < close[3]

bull_ob = show_ob and bull_impulse and close[3] < open[3]  // last candle was bearish
bear_ob = show_ob and bear_impulse and close[3] > open[3]  // last candle was bullish

if bull_ob
    box.new(bar_index - 3, math.min(open[3], close[3]),
            bar_index + 30, math.max(open[3], close[3]),
            border_color=color.new(color.green, 60),
            bgcolor=ob_bull_col, border_width=1)

if bear_ob
    box.new(bar_index - 3, math.min(open[3], close[3]),
            bar_index + 30, math.max(open[3], close[3]),
            border_color=color.new(color.red, 60),
            bgcolor=ob_bear_col, border_width=1)

// ─── LIQUIDITY POOLS (equal H/L) ──────────────────────────────────────────────
tol = eq_tolerance / 100

// Sell-side liquidity (SSL): equal lows (buy stops resting below)
is_ssl = show_ssl and math.abs(low - low[1]) / low < tol and math.abs(low - low[2]) / low < tol
// Buy-side liquidity (BSL): equal highs (sell stops resting above)
is_bsl = show_bsl and math.abs(high - high[1]) / high < tol and math.abs(high - high[2]) / high < tol

plotshape(is_ssl, "SSL", shape.triangledown, location.belowbar,
          color=color.new(color.red, 0), size=size.tiny)
plotshape(is_bsl, "BSL", shape.triangleup,  location.abovebar,
          color=color.new(color.green, 0), size=size.tiny)
