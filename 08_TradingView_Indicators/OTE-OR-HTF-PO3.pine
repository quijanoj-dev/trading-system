// ----------------------------------------------------------------------------
// PO3 – Drawing objects arrays
// ----------------------------------------------------------------------------
var array<box>  po3_htf1CandleBodies = array.new<box>(6, na)
var array<line> po3_htf1UpperWicks   = array.new<line>(6, na)
var array<line> po3_htf1LowerWicks   = array.new<line>(6, na)

var array<box>  po3_htf2CandleBodies = array.new<box>(6, na)
var array<line> po3_htf2UpperWicks   = array.new<line>(6, na)
var array<line> po3_htf2LowerWicks   = array.new<line>(6, na)

var array<box>  po3_htf3CandleBodies = array.new<box>(6, na)
var array<line> po3_htf3UpperWicks   = array.new<line>(6, na)
var array<line> po3_htf3LowerWicks   = array.new<line>(6, na)

var array<box>  po3_htf4CandleBodies = array.new<box>(6, na)
var array<line> po3_htf4UpperWicks   = array.new<line>(6, na)
var array<line> po3_htf4LowerWicks   = array.new<line>(6, na)

// FVG box storage: max 4×4 = 16 FVGs across all groups
var array<box> po3_fvgBoxes = array.new<box>(16, na)

// Volume bar box storage
var array<box> po3_htf1VolBars = array.new<box>(6, na)
var array<box> po3_htf2VolBars = array.new<box>(6, na)
var array<box> po3_htf3VolBars = array.new<box>(6, na)
var array<box> po3_htf4VolBars = array.new<box>(6, na)

// Volume MA line storage (5 segments per group connecting 6 points)
var array<line> po3_htf1MALines = array.new<line>(5, na)
var array<line> po3_htf2MALines = array.new<line>(5, na)
var array<line> po3_htf3MALines = array.new<line>(5, na)
var array<line> po3_htf4MALines = array.new<line>(5, na)

// Separator lines: future ext + between HTF1/2, HTF2/3, HTF3/4
var array<line> po3_separatorLines = array.new<line>(4, na)
// Group title labels
var array<label> po3_groupTitles = array.new<label>(4, na)

// ----------------------------------------------------------------------------
// PO3 – Stable chart range (OPT #5: cached with var, only updated on confirmed/last bar)
// ----------------------------------------------------------------------------
var float po3_refHigh  = na
var float po3_refLow   = na
if barstate.isconfirmed or barstate.islast
    po3_refHigh := ta.highest(high, 100)
    po3_refLow  := ta.lowest(low, 100)
float po3_refRange = nz(po3_refHigh - po3_refLow)

// Ensure a minimum range using ATR to avoid tiny ranges on flat markets
float po3_minRange = ta.atr(14) * 8
float po3_chartRange = math.max(po3_refRange, po3_minRange)

float po3_chartMid   = (nz(po3_refHigh) + nz(po3_refLow)) / 2.0
float po3_chartHigh  = po3_chartMid + po3_chartRange / 2.0
float po3_chartLow   = po3_chartMid - po3_chartRange / 2.0

// ----------------------------------------------------------------------------
// PO3 – Per-group scaling: compress candles that exceed chart range
// ----------------------------------------------------------------------------
po3_f_scaleGroup(opens, highs, lows, closes, count, _chartHigh, _chartLow, visualWeight) =>
    float gHigh = na
    float gLow = na
    for i = 0 to count - 1
        _h = array.get(highs, i)
        _l = array.get(lows, i)
        if not na(_h)
            gHigh := na(gHigh) ? _h : math.max(gHigh, _h)
        if not na(_l)
            gLow := na(gLow) ? _l : math.min(gLow, _l)
    if not na(gHigh) and not na(gLow)
        chartRange = _chartHigh - _chartLow
        groupRange = gHigh - gLow
        groupMid   = (gHigh + gLow) / 2.0
        chartMid   = (_chartHigh + _chartLow) / 2.0
        baseFactor  = groupRange > chartRange * 0.95 ? (chartRange * 0.85) / groupRange : 1.0
        scaleFactor = baseFactor * visualWeight
        for i = 0 to count - 1
            o = array.get(opens, i)
            if not na(o)
                array.set(opens,  i, chartMid + (o - groupMid) * scaleFactor)
                array.set(highs,  i, chartMid + (array.get(highs, i) - groupMid) * scaleFactor)
                array.set(lows,   i, chartMid + (array.get(lows, i) - groupMid) * scaleFactor)
                array.set(closes, i, chartMid + (array.get(closes, i) - groupMid) * scaleFactor)
    true
// OPT #9: Extracted candle-drawing helper (replaces 4 × 16 lines with 4 × 1 call)
po3_f_drawGroup(array<float> opens, array<float> highs, array<float> lows, array<float> closes, array<int> candleCounts, array<box> bodies, array<line> upWicks, array<line> dnWicks, int futExt) =>
    for i = 0 to 5
        xO = array.get(opens, i)
        xH = array.get(highs, i)
        xL = array.get(lows,  i)
        xC = array.get(closes, i)
        if na(xO) or na(xH) or na(xL) or na(xC)
            continue
        candleCount = array.get(candleCounts, i) + futExt
        bodyLeftBar  = bar_index + candleCount
        bodyRightBar = bar_index + candleCount + 2
        wickBar      = bar_index + candleCount + 1
        po3_f_drawCandle(xO, xH, xL, xC, bodyLeftBar, bodyRightBar, wickBar, bodies, upWicks, dnWicks, i)
    true

// OPT #12: Extracted group title helper
po3_f_addGroupTitle(array<float> opens, array<float> closes, string tfInput, array<int> candleCounts, array<label> titles, int idx, float topY, int futExt, string bullArrow, string bearArrow, color bullColor, color bearColor, string lblSize) =>
    firstO = array.get(opens, 0)
    lastC  = array.get(closes, 5)
    isBull = not na(firstO) and not na(lastC) ? lastC >= firstO : true
    title  = po3_f_tfText(tfInput) + (isBull ? bullArrow : bearArrow)
    centerX = bar_index + math.round((array.get(candleCounts, 0) + array.get(candleCounts, 5)) / 2) + futExt + 1
    array.set(titles, idx, label.new(centerX, topY, title, style=label.style_none, textcolor=isBull ? bullColor : bearColor, size=lblSize))
    true

// ----------------------------------------------------------------------------
// PO3 – Drawing logic (only on last bar)
// ----------------------------------------------------------------------------
// --- OPT #6: Consolidated cleanup helper (top-level scope required by Pine) ---
po3_f_cleanupGroup(array<box> bodies, array<line> upW, array<line> dnW, array<box> vBars, bool showVol) =>
    for i = 0 to 5
        box body = array.get(bodies, i)
        line up = array.get(upW, i)
        line dn = array.get(dnW, i)
        if not na(body)
            box.delete(body)
            array.set(bodies, i, na)
        if not na(up)
            line.delete(up)
            array.set(upW, i, na)
        if not na(dn)
            line.delete(dn)
            array.set(dnW, i, na)
        if showVol
            box vb = array.get(vBars, i)
            if not na(vb)
                box.delete(vb)
                array.set(vBars, i, na)
    true

if barstate.islast
    po3_f_cleanupGroup(po3_htf1CandleBodies, po3_htf1UpperWicks, po3_htf1LowerWicks, po3_htf1VolBars, po3_showVolume)
    po3_f_cleanupGroup(po3_htf2CandleBodies, po3_htf2UpperWicks, po3_htf2LowerWicks, po3_htf2VolBars, po3_showVolume)
    po3_f_cleanupGroup(po3_htf3CandleBodies, po3_htf3UpperWicks, po3_htf3LowerWicks, po3_htf3VolBars, po3_showVolume)
    po3_f_cleanupGroup(po3_htf4CandleBodies, po3_htf4UpperWicks, po3_htf4LowerWicks, po3_htf4VolBars, po3_showVolume)
    // Clean up volume MA lines (guarded)
    if po3_showVolume and po3_showVolMA
        for i = 0 to 4
            line ma1 = array.get(po3_htf1MALines, i)
            line ma2 = array.get(po3_htf2MALines, i)
            line ma3 = array.get(po3_htf3MALines, i)
            line ma4 = array.get(po3_htf4MALines, i)
            if not na(ma1)
                line.delete(ma1)
                array.set(po3_htf1MALines, i, na)
            if not na(ma2)
                line.delete(ma2)
                array.set(po3_htf2MALines, i, na)
            if not na(ma3)
                line.delete(ma3)
                array.set(po3_htf3MALines, i, na)
            if not na(ma4)
                line.delete(ma4)
                array.set(po3_htf4MALines, i, na)
    // Clean up FVG boxes (guarded)
    if po3_showFVG
        for i = 0 to array.size(po3_fvgBoxes) - 1
            box fvg = array.get(po3_fvgBoxes, i)
            if not na(fvg)
                box.delete(fvg)
                array.set(po3_fvgBoxes, i, na)

    // Clean up separator lines and group titles
    for i = 0 to 3
        line sep = array.get(po3_separatorLines, i)
        label ttl = array.get(po3_groupTitles, i)
        if not na(sep)
            line.delete(sep)
            array.set(po3_separatorLines, i, na)
        if not na(ttl)
            label.delete(ttl)
            array.set(po3_groupTitles, i, na)

    // --- Visual weights ---
    float po3_vw1 = 0.50
    float po3_vw2 = 0.65
    float po3_vw3 = 0.80
    float po3_vw4 = 1.00

    // --- Unified layout: partition stable range into zones (all fits on screen) ---
    // Layout: [layoutBottom] volume region | gap | candle region [layoutTop]
    // The TradingView native Canvas Margins handle actual screen breathing room.
    float layoutTop    = po3_chartHigh
    float layoutBottom = po3_chartLow

    float volRegionHeight = po3_chartRange * (po3_volumeHeight / 100.0)
    float volGapSize      = po3_chartRange * (po3_volumeGap / 100.0)

    // Volume base sits directly on the bottom edge
    float volBase      = layoutBottom
    // Candle region fills from above volume+gap to the very top edge
    float scalingLow   = po3_showVolume ? (volBase + volRegionHeight + volGapSize) : layoutBottom
    float scalingHigh  = layoutTop

    // --- Scale HTF groups with progressive visual weight (using shifted center) ---
    po3_f_scaleGroup(po3_htf1Opens, po3_htf1Highs, po3_htf1Lows, po3_htf1Closes, 6, scalingHigh, scalingLow, po3_vw1)
    po3_f_scaleGroup(po3_htf2Opens, po3_htf2Highs, po3_htf2Lows, po3_htf2Closes, 6, scalingHigh, scalingLow, po3_vw2)
    po3_f_scaleGroup(po3_htf3Opens, po3_htf3Highs, po3_htf3Lows, po3_htf3Closes, 6, scalingHigh, scalingLow, po3_vw3)
    po3_f_scaleGroup(po3_htf4Opens, po3_htf4Highs, po3_htf4Lows, po3_htf4Closes, 6, scalingHigh, scalingLow, po3_vw4)

    // --- OPT #9: Draw all 4 HTF groups via helper ---
    po3_f_drawGroup(po3_htf1Opens, po3_htf1Highs, po3_htf1Lows, po3_htf1Closes, po3_htf1CandleCounts, po3_htf1CandleBodies, po3_htf1UpperWicks, po3_htf1LowerWicks, global_futureExtension)
    po3_f_drawGroup(po3_htf2Opens, po3_htf2Highs, po3_htf2Lows, po3_htf2Closes, po3_htf2CandleCounts, po3_htf2CandleBodies, po3_htf2UpperWicks, po3_htf2LowerWicks, global_futureExtension)
    po3_f_drawGroup(po3_htf3Opens, po3_htf3Highs, po3_htf3Lows, po3_htf3Closes, po3_htf3CandleCounts, po3_htf3CandleBodies, po3_htf3UpperWicks, po3_htf3LowerWicks, global_futureExtension)
    po3_f_drawGroup(po3_htf4Opens, po3_htf4Highs, po3_htf4Lows, po3_htf4Closes, po3_htf4CandleCounts, po3_htf4CandleBodies, po3_htf4UpperWicks, po3_htf4LowerWicks, global_futureExtension)

    // --- Per-group volume max heights (visual weight applied) ---
    float volH1 = volRegionHeight * po3_vw1
    float volH2 = volRegionHeight * po3_vw2
    float volH3 = volRegionHeight * po3_vw3
    float volH4 = volRegionHeight * po3_vw4

    // --- FVG Detection & Drawing ---
    if po3_showFVG
        int fvgIdx = 0
        fvgIdx := po3_f_drawFVGs(po3_htf1Highs, po3_htf1Lows, po3_htf1CandleCounts, 6, po3_fvgBoxes, fvgIdx)
        fvgIdx := po3_f_drawFVGs(po3_htf2Highs, po3_htf2Lows, po3_htf2CandleCounts, 6, po3_fvgBoxes, fvgIdx)
        fvgIdx := po3_f_drawFVGs(po3_htf3Highs, po3_htf3Lows, po3_htf3CandleCounts, 6, po3_fvgBoxes, fvgIdx)
        fvgIdx := po3_f_drawFVGs(po3_htf4Highs, po3_htf4Lows, po3_htf4CandleCounts, 6, po3_fvgBoxes, fvgIdx)

    // --- Separator Lines & Group Titles ---
    float sepTop = scalingHigh
    float sepBottomFinal = po3_showVolume ? volBase : scalingLow

    // Separator X positions: centered between last candle right edge and next group first candle left edge
    int sep1X = bar_index + math.round((array.get(po3_htf1CandleCounts, 5) + array.get(po3_htf2CandleCounts, 0)) / 2) + global_futureExtension
    int sep2X = bar_index + math.round((array.get(po3_htf2CandleCounts, 5) + array.get(po3_htf3CandleCounts, 0)) / 2) + global_futureExtension
    int sep3X = bar_index + math.round((array.get(po3_htf3CandleCounts, 5) + array.get(po3_htf4CandleCounts, 0)) / 2) + global_futureExtension
    int sep4X = bar_index + global_futureExtension + math.round(po3_gapBetweenGroups / 2)  // Future Extension: centered in gap before HTF1

    if po3_showSeparators
        po3_sepLineSty = po3_separatorStyleS == "Dashed" ? line.style_dashed : po3_separatorStyleS == "Dotted" ? line.style_dotted : line.style_solid
        array.set(po3_separatorLines, 0, line.new(sep4X, sepTop, sep4X, sepBottomFinal, color=po3_separatorColor, width=1, style=po3_sepLineSty))
        array.set(po3_separatorLines, 1, line.new(sep1X, sepTop, sep1X, sepBottomFinal, color=po3_separatorColor, width=1, style=po3_sepLineSty))
        array.set(po3_separatorLines, 2, line.new(sep2X, sepTop, sep2X, sepBottomFinal, color=po3_separatorColor, width=1, style=po3_sepLineSty))
        array.set(po3_separatorLines, 3, line.new(sep3X, sepTop, sep3X, sepBottomFinal, color=po3_separatorColor, width=1, style=po3_sepLineSty))

    // --- Volume Bars (shared floor, visual weight on max height) ---
    if po3_showVolume
        float maxVol1 = po3_f_drawVolBars(po3_htf1Vols, po3_htf1Opens, po3_htf1Closes, po3_htf1CandleCounts, 6, po3_htf1VolBars, volBase, volH1, po3_greenCandle, po3_redCandle)
        float maxVol2 = po3_f_drawVolBars(po3_htf2Vols, po3_htf2Opens, po3_htf2Closes, po3_htf2CandleCounts, 6, po3_htf2VolBars, volBase, volH2, po3_greenCandle, po3_redCandle)
        float maxVol3 = po3_f_drawVolBars(po3_htf3Vols, po3_htf3Opens, po3_htf3Closes, po3_htf3CandleCounts, 6, po3_htf3VolBars, volBase, volH3, po3_greenCandle, po3_redCandle)
        float maxVol4 = po3_f_drawVolBars(po3_htf4Vols, po3_htf4Opens, po3_htf4Closes, po3_htf4CandleCounts, 6, po3_htf4VolBars, volBase, volH4, po3_greenCandle, po3_redCandle)
        // Volume MA lines
        if po3_showVolMA
            po3_f_drawVolMA(po3_htf1VolMA, po3_htf1CandleCounts, 6, po3_htf1MALines, volBase, volH1, maxVol1, po3_volMAColor)
            po3_f_drawVolMA(po3_htf2VolMA, po3_htf2CandleCounts, 6, po3_htf2MALines, volBase, volH2, maxVol2, po3_volMAColor)
            po3_f_drawVolMA(po3_htf3VolMA, po3_htf3CandleCounts, 6, po3_htf3MALines, volBase, volH3, maxVol3, po3_volMAColor)
            po3_f_drawVolMA(po3_htf4VolMA, po3_htf4CandleCounts, 6, po3_htf4MALines, volBase, volH4, maxVol4, po3_volMAColor)

    if po3_showGroupTitles
        // OPT #12: Group titles via helper
        string bullArrow = " ⤴"
        string bearArrow = " ⤵"
        po3_f_addGroupTitle(po3_htf1Opens, po3_htf1Closes, po3_htf1Input, po3_htf1CandleCounts, po3_groupTitles, 0, sepTop, global_futureExtension, bullArrow, bearArrow, po3_titleBullColor, po3_titleBearColor, po3_labelSizeFinal)
        po3_f_addGroupTitle(po3_htf2Opens, po3_htf2Closes, po3_htf2Input, po3_htf2CandleCounts, po3_groupTitles, 1, sepTop, global_futureExtension, bullArrow, bearArrow, po3_titleBullColor, po3_titleBearColor, po3_labelSizeFinal)
        po3_f_addGroupTitle(po3_htf3Opens, po3_htf3Closes, po3_htf3Input, po3_htf3CandleCounts, po3_groupTitles, 2, sepTop, global_futureExtension, bullArrow, bearArrow, po3_titleBullColor, po3_titleBearColor, po3_labelSizeFinal)
        po3_f_addGroupTitle(po3_htf4Opens, po3_htf4Closes, po3_htf4Input, po3_htf4CandleCounts, po3_groupTitles, 3, sepTop, global_futureExtension, bullArrow, bearArrow, po3_titleBullColor, po3_titleBearColor, po3_labelSizeFinal)

// ============================================================================
// END OF MODULE 3 (HTF PO3)
// ============================================================================
